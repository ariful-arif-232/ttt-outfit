<%- include('partials/header') %>

<section class="auth-page-section">

  <div class="container auth-page-container">

    <div class="auth-premium-card">

      <aside class="auth-brand-panel">

        <div class="auth-brand-content">

          <a href="/" class="auth-logo-link">
            <img
              src="/ttt-logo.jpeg"
              alt="TTT Outfit"
            >

            <span>
              TTT <strong>OUTFIT</strong>
            </span>
          </a>

          <span class="auth-kicker">
            SECURE PASSWORD RESET
          </span>

          <h1>
            Create a New
            <em>Password.</em>
          </h1>

          <p>
            Choose a strong password that you have
            not used before.
          </p>

        </div>

      </aside>


      <div class="auth-form-panel">

        <header class="auth-form-header">

          <span class="section-kicker">
            NEW PASSWORD
          </span>

          <h2>Secure your account</h2>

          <p>
            Your password must contain at least 8 characters.
          </p>

        </header>


        <form
          class="premium-auth-form"
          method="post"
          action="/reset-password/<%= token %>"
        >

          <div class="field">

            <label for="newPassword">
              New Password
            </label>

            <div class="auth-input-wrap">

              <i class="bi bi-lock"></i>

              <input
                id="newPassword"
                type="password"
                name="password"
                minlength="8"
                placeholder="Minimum 8 characters"
                autocomplete="new-password"
                required
              >

              <button
                class="auth-password-toggle"
                type="button"
                data-password-toggle="newPassword"
                aria-label="Show password"
              >
                <i class="bi bi-eye"></i>
              </button>

            </div>

          </div>


          <div class="field">

            <label for="confirmNewPassword">
              Confirm New Password
            </label>

            <div class="auth-input-wrap">

              <i class="bi bi-shield-lock"></i>

              <input
                id="confirmNewPassword"
                type="password"
                name="confirmPassword"
                minlength="8"
                placeholder="Repeat the new password"
                autocomplete="new-password"
                required
              >

              <button
                class="auth-password-toggle"
                type="button"
                data-password-toggle="confirmNewPassword"
                aria-label="Show password"
              >
                <i class="bi bi-eye"></i>
              </button>

            </div>

          </div>


          <button
            class="btn auth-submit-button"
            type="submit"
          >
            Update Password
            <i class="bi bi-check-circle"></i>
          </button>

        </form>


        <p class="auth-switch-message">

          Return to

          <a href="/auth?tab=login">
            Login
          </a>

        </p>

      </div>

    </div>

  </div>

</section>


<script>
  document.addEventListener(
    'DOMContentLoaded',
    () => {
      document
        .querySelectorAll(
          '[data-password-toggle]'
        )
        .forEach(button => {
          button.addEventListener(
            'click',
            () => {
              const input =
                document.getElementById(
                  button.dataset.passwordToggle
                );

              if (!input) return;

              const showPassword =
                input.type === 'password';

              input.type =
                showPassword
                  ? 'text'
                  : 'password';

              const icon =
                button.querySelector('i');

              icon?.classList.toggle(
                'bi-eye',
                !showPassword
              );

              icon?.classList.toggle(
                'bi-eye-slash',
                showPassword
              );
            }
          );
        });
    }
  );
</script>

<%- include('partials/footer') %>
