<%- include('partials/header') %><section class="section"><div class="container"><div class="section-head"><h2>Shop</h2><span><%= products.length %> products</span></div><form class="filters" method="get"><input name="q" placeholder="Search products" value="<%= filters.q %>"><select name="category"><option value="">All categories</option><% categories.forEach(c=>{ %><option <%= filters.category===c?'selected':'' %>><%= c %></option><% }) %></select><select name="sort"><option value="newest" <%= filters.sort==='newest'?'selected':'' %>>Newest</option><option value="price_low" <%= filters.sort==='price_low'?'selected':'' %>>Price: low to high</option><option value="price_high" <%= filters.sort==='price_high'?'selected':'' %>>Price: high to low</option><option value="popular" <%= filters.sort==='popular'?'selected':'' %>>Popular</option></select><button class="btn">Apply</button></form><div class="grid"><% products.forEach(p=>{ %><%- include('partials/product-card',{p}) %><% }) %></div></div></section><%- include('partials/footer') %>
