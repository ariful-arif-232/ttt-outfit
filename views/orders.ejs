<%- include('partials/header') %><section class="section"><div class="container"><h1>My orders</h1><% if(!orders.length){ %><div class="panel">You have no orders yet.</div><% } orders.forEach(o=>{ %><a class="order-card" style="display:block" href="/orders/<%= o._id %>"><strong><%= o.orderNumber %></strong><span class="status" style="float:right"><%= o.status %></span><p><%= o.items.length %> item(s) · ৳<%= money(o.total) %></p><p class="small"><%= new Date(o.createdAt).toLocaleString() %> · Payment: <%= o.paymentStatus %></p></a><% }) %></div></section><%- include('partials/footer') %>
