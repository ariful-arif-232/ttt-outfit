<%- include('partials/header') %>

<!-- =====================================
     HERO SLIDER
===================================== -->

<section class="hero-slider" aria-label="Promotional collections">

  <!-- Slide 1 -->
  <article
    class="hero-slide hero-slide-one active"
    aria-hidden="false"
  >
    <div class="hero-content-wrap">
      <div class="container">
        <div class="hero-text">

          <span class="hero-kicker">
            SUMMER COLLECTION
          </span>

          <h1>
            Up to <em>30% Off</em>
          </h1>

          <p>
            Upgrade your everyday wardrobe with premium
            summer essentials from TTT Outfit.
          </p>

          <div class="hero-actions">
            <a class="btn gold-btn" href="/shop">
              Shop Now
            </a>

            <a class="btn outline-btn" href="#categories">
              Explore Categories
            </a>
          </div>

        </div>
      </div>
    </div>
  </article>

  <!-- Slide 2 -->
  <article
    class="hero-slide hero-slide-two"
    aria-hidden="true"
  >
    <div class="hero-content-wrap">
      <div class="container">
        <div class="hero-text">

          <span class="hero-kicker">
            NEW ARRIVALS
          </span>

          <h1>
            Fresh <em>Drop</em>
          </h1>

          <p>
            Discover our latest casual fashion,
            confident fits and premium everyday styles.
          </p>

          <div class="hero-actions">
            <a class="btn gold-btn" href="/shop">
              Explore Collection
            </a>
          </div>

        </div>
      </div>
    </div>
  </article>

  <!-- Slide 3 -->
  <article
    class="hero-slide hero-slide-three"
    aria-hidden="true"
  >
    <div class="hero-content-wrap">
      <div class="container">
        <div class="hero-text">

          <span class="hero-kicker">
            STREETWEAR EDIT
          </span>

          <h1>
            Drop <em>Shoulder</em>
          </h1>

          <p>
            Relaxed silhouettes and modern streetwear
            designed for effortless everyday style.
          </p>

          <div class="hero-actions">
            <a
              class="btn gold-btn"
              href="/shop?category=Drop%20Shoulder"
            >
              Shop Streetwear
            </a>
          </div>

        </div>
      </div>
    </div>
  </article>

  <!-- Slide 4 -->
  <article
    class="hero-slide hero-slide-four"
    aria-hidden="true"
  >
    <div class="hero-content-wrap">
      <div class="container">
        <div class="hero-text">

          <span class="hero-kicker">
            SMART CASUAL
          </span>

          <h1>
            Classic <em>Polo</em>
          </h1>

          <p>
            Clean, refined polo shirts made for
            comfort, confidence and every occasion.
          </p>

          <div class="hero-actions">
            <a
              class="btn gold-btn"
              href="/shop?category=Polo"
            >
              Shop Polo
            </a>
          </div>

        </div>
      </div>
    </div>
  </article>

  <!-- Slide 5 -->
  <article
    class="hero-slide hero-slide-five"
    aria-hidden="true"
  >
    <div class="hero-content-wrap">
      <div class="container">
        <div class="hero-text">

          <span class="hero-kicker">
            LIMITED OFFER
          </span>

          <h1>
            Premium <em>Essentials</em>
          </h1>

          <p>
            Limited-time prices on selected TTT Outfit
            products while stocks last.
          </p>

          <div class="hero-actions">
            <a class="btn gold-btn" href="/shop">
              View Offers
            </a>
          </div>

        </div>
      </div>
    </div>
  </article>

  <button
    class="hero-arrow hero-prev"
    type="button"
    aria-label="Previous slide"
  >
    &#10094;
  </button>

  <button
    class="hero-arrow hero-next"
    type="button"
    aria-label="Next slide"
  >
    &#10095;
  </button>

  <div class="hero-dots" aria-label="Choose a slide">

    <% for (let i = 0; i < 5; i++) { %>
      <button
        class="hero-dot <%= i === 0 ? 'active' : '' %>"
        type="button"
        aria-label="Go to slide <%= i + 1 %>"
      ></button>
    <% } %>

  </div>

</section>


<!-- =====================================
     CATEGORIES
===================================== -->

<section
  class="section category-section"
  id="categories"
>
  <div class="container">

    <header class="section-title reveal hero-matched-title">
      <h2>Find your style</h2>
    </header>
<div class="category-showcase-layout">

<div class="category-video-feature">

  <video
    class="category-feature-video"
    autoplay
    muted
    loop
    playsinline
    preload="none"
poster="/videos/video-poster.jpg"
  >
    <source
      src="/videos/ttt-fashion.mp4"
      type="video/mp4"
    >
  </video>

  <div class="category-video-overlay"></div>

  <div class="category-video-content">

    <span class="category-video-label">
      NEW SEASON
    </span>

    <h2>
      Style in Motion
    </h2>

    <p>
      Premium everyday fashion designed for comfort,
      confidence and modern life.
    </p>

    <a
      href="/shop"
      class="category-video-button"
    >
      Shop Collection
      <i class="bi bi-arrow-right"></i>
    </a>

  </div>

</div>
    <div class="premium-category-grid">

      <a
        class="premium-category-card reveal"
        href="/shop?category=T-Shirts"
      >
        <img
          src="/category-tshirt.jpg"
          alt="TTT Outfit T-Shirts"
          loading="lazy"
        >

        <div class="premium-category-overlay">
          <span class="category-label">
            TTT ESSENTIALS
          </span>

          <h3>T-Shirts</h3>

          <span class="category-shop-link">
            Shop collection
            <strong>→</strong>
          </span>
        </div>
      </a>

      <a
        class="premium-category-card reveal"
        href="/shop?category=Polo"
      >
        <img
          src="/category-polo.jpg"
          alt="TTT Outfit Polo Shirts"
          loading="lazy"
        >

        <div class="premium-category-overlay">
          <span class="category-label">
            SMART CASUAL
          </span>

          <h3>Polo Shirts</h3>

          <span class="category-shop-link">
            Shop collection
            <strong>→</strong>
          </span>
        </div>
      </a>

      <a
        class="premium-category-card reveal"
        href="/shop?category=Drop%20Shoulder"
      >
        <img
          src="/category-drop-shoulder.jpg"
          alt="TTT Outfit Drop Shoulder"
          loading="lazy"
        >

        <div class="premium-category-overlay">
          <span class="category-label">
            STREETWEAR
          </span>

          <h3>Drop Shoulder</h3>

          <span class="category-shop-link">
            Shop collection
            <strong>→</strong>
          </span>
        </div>
      </a>

      <a
        class="premium-category-card reveal"
        href="/shop?category=Jackets"
      >
        <img
          src="/category-jacket.jpg"
          alt="TTT Outfit Jackets"
          loading="lazy"
        >

        <div class="premium-category-overlay">
          <span class="category-label">
            URBAN LAYERS
          </span>

          <h3>Jackets</h3>

          <span class="category-shop-link">
            Shop collection
            <strong>→</strong>
          </span>
        </div>
      </a>

    </div>

</div>

  </div>
</section>


<!-- =====================================
     FEATURED PRODUCTS
===================================== -->

<section class="section products-section">
  <div class="container">

    <header class="section-head reveal">
      <div>
        <span class="section-kicker">
          CURATED FOR YOU
        </span>

        <h2>Featured products</h2>
      </div>

<div class="featured-actions">

    <a class="view-all-link" href="/shop">
        View all products →
    </a>

    <span class="featured-offer">
        GET <strong>20%</strong> OFF
    </span>

</div>
    </header>

    <% if (featured && featured.length) { %>

      <div class="grid product-grid">
        <% featured.forEach((p, index) => { %>

          <div
            class="reveal"
            style="transition-delay:
              <%= Math.min(index * 70, 350) %>ms;"
          >
            <%- include('partials/product-card', {
    p,
    hideOfferButton: true
}) %>
          </div>

        <% }) %>
      </div>

    <% } else { %>

      <div class="empty-products reveal">
        <h3>New products coming soon</h3>

        <p>
          Add featured products from your admin panel
          to display them here.
        </p>

        <a class="btn" href="/shop">
          Browse Shop
        </a>
      </div>

    <% } %>

  </div>
</section>


<!-- =====================================
     PROMO BANNER
===================================== -->

<section class="promo-banner">
  <div class="container promo-content reveal">

    <div>
      <span class="section-kicker gold-text">
        TTT OUTFIT
      </span>

      <h2>
        Fashion created for
        <em>confidence.</em>
      </h2>

      <p>
        Build your everyday wardrobe with premium
        clothing designed for comfort and style.
      </p>
    </div>

    <a class="btn gold-btn" href="/shop">
      Discover Collection
    </a>

  </div>
</section>


<!-- =====================================
     WHY CHOOSE US
===================================== -->

<section class="section">
  <div class="container">

    <header class="section-title reveal">
      <span class="section-kicker">
        WHY TTT OUTFIT
      </span>

      <h2>Designed around you</h2>
    </header>

    <div class="why-grid">

      <article class="why-card reveal">
        <span>01</span>

        <h3>Quality Fabrics</h3>

        <p>
          Selected materials for everyday comfort,
          durability and a premium feel.
        </p>
      </article>

      <article class="why-card reveal">
        <span>02</span>

        <h3>Modern Design</h3>

        <p>
          Clean and confident styles for casual,
          streetwear and smart-casual occasions.
        </p>
      </article>

      <article class="why-card reveal">
        <span>03</span>

        <h3>Nationwide Delivery</h3>

        <p>
          Convenient ordering and dependable delivery
          support across Bangladesh.
        </p>
      </article>

    </div>

  </div>
</section>


<!-- =====================================
     NEWSLETTER
===================================== -->

<section class="newsletter-section">
  <div class="container newsletter reveal">

    <div>
      <span class="section-kicker gold-text">
        STAY UPDATED
      </span>

      <h2>Join the TTT community</h2>

      <p>
        Get updates about new collections,
        promotions and exclusive offers.
      </p>
    </div>

    <form
      class="newsletter-form"
      onsubmit="
        event.preventDefault();
        this.reset();
        alert('Thank you for subscribing!');
      "
    >
      <input
        type="email"
        name="newsletterEmail"
        placeholder="Enter your email address"
        aria-label="Email address"
        required
      >

      <button class="btn gold-btn" type="submit">
        Subscribe
      </button>
    </form>

  </div>
</section>

<%- include('partials/footer') %>
