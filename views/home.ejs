<%- include('partials/header') %>

<% const activeSlides = (sliders || []).length ? sliders : [{ desktopImage: '/hero-1.jpg', mobileImage: '/hero-1-mobile.jpg', subtitle: 'NEW COLLECTION', title: 'Wear Your Identity', description: 'Premium everyday fashion designed for confidence, comfort and modern life.', buttonText: 'Shop Now', buttonLink: '/shop', textPosition: 'center-left' }]; %>
<section class="ttt-hero" data-hero-slider aria-label="Featured collections">
  <div class="ttt-hero-track">
    <% activeSlides.forEach(function(slide, index) { %>
      <article class="ttt-hero-slide <%= index === 0 ? 'is-active' : '' %> ttt-position-<%= slide.textPosition || 'center-left' %>" aria-hidden="<%= index === 0 ? 'false' : 'true' %>">
        <picture>
          <% if (slide.mobileImage) { %><source media="(max-width: 700px)" srcset="<%= slide.mobileImage %>"><% } %>
          <img src="<%= slide.desktopImage || '/hero-1.jpg' %>" alt="<%= slide.title || 'TTT Outfit collection' %>" <%= index === 0 ? 'fetchpriority="high"' : 'loading="lazy"' %>>
        </picture>
        <div class="ttt-hero-overlay"></div>
        <div class="ttt-hero-content">
          <% if (slide.subtitle) { %><span class="ttt-eyebrow"><%= slide.subtitle %></span><% } %>
          <h1><%= slide.title || 'Wear Your Identity' %></h1>
          <% if (slide.description) { %><p><%= slide.description %></p><% } %>
          <% if (slide.buttonText) { %><a class="ttt-primary-button" href="<%= slide.buttonLink || '/shop' %>"><%= slide.buttonText %></a><% } %>
        </div>
      </article>
    <% }); %>
  </div>
  <% if (activeSlides.length > 1) { %>
    <button class="ttt-hero-arrow ttt-hero-prev" type="button" aria-label="Previous slide"><i class="bi bi-arrow-left"></i></button>
    <button class="ttt-hero-arrow ttt-hero-next" type="button" aria-label="Next slide"><i class="bi bi-arrow-right"></i></button>
    <div class="ttt-hero-dots" role="tablist" aria-label="Choose slide">
      <% activeSlides.forEach(function(_, index) { %><button type="button" class="<%= index === 0 ? 'is-active' : '' %>" role="tab" aria-selected="<%= index === 0 ? 'true' : 'false' %>" tabindex="<%= index === 0 ? '0' : '-1' %>" aria-label="Go to slide <%= index + 1 %>"></button><% }); %>
    </div>
  <% } %>
</section>

<section class="ttt-showcase" id="categories">
  <div class="ttt-section-heading ttt-reveal">
    <span>READY TO WEAR</span>
    <h2>TOP COLLECTION</h2>
  </div>
  <div class="ttt-showcase-grid">
    <% const showcase = (showcaseCategories || []).length ? showcaseCategories : [
      {name:'T-Shirt', image:'/category-tshirt.jpg', buttonText:'Explore Collection'},
      {name:'Polo Shirt', image:'/category-polo.jpg', buttonText:'Shop Polo'},
      {name:'Drop Shoulder T-Shirt', image:'/category-drop-shoulder.jpg', buttonText:'Discover Now'},
      {name:'Jacket', image:'/category-jacket.jpg', buttonText:'View Collection'}
    ]; %>
    <% showcase.forEach(function(cat) { %>
      <a class="ttt-showcase-card ttt-reveal" href="/shop?category=<%= encodeURIComponent(cat.name) %>">
        <img src="<%= cat.image || '/ttt-logo.jpeg' %>" alt="<%= cat.name %>" loading="lazy" decoding="async" data-image-fallback="/ttt-logo.jpeg">
        <span class="ttt-showcase-shade"></span>
        <span class="ttt-showcase-copy"><strong><%= cat.name %></strong><em><%= cat.buttonText || 'Shop Now' %> <i class="bi bi-arrow-right"></i></em></span>
      </a>
    <% }); %>
  </div>
</section>

<section class="ttt-category-rails" aria-label="Shop by category">
  <% if ((categorySections || []).length) { %>
    <% categorySections.forEach(function(section, sectionIndex) { if ((section.products || []).length) { %>
      <article class="ttt-product-section ttt-reveal" data-product-rail-section>
        <div class="ttt-product-section-head">
          <div><span><%= section.category.offerText || 'GET 20% OFF' %></span><h2><%= section.category.name %></h2></div>
          <div class="ttt-product-section-actions">
            <a href="/shop?category=<%= encodeURIComponent(section.category.name) %>">View All</a>
            <button type="button" data-rail-prev aria-label="Previous products"><i class="bi bi-arrow-left"></i></button>
            <button type="button" data-rail-next aria-label="Next products"><i class="bi bi-arrow-right"></i></button>
          </div>
        </div>
        <div class="ttt-product-rail" data-product-rail>
          <% section.products.forEach(function(p) { %><div class="ttt-product-rail-item"><%- include('partials/product-card', { p, hideOfferButton: true }) %></div><% }); %>
        </div>
      </article>
    <% } }); %>
  <% } else if ((featured || []).length) { %>
    <article class="ttt-product-section ttt-reveal" data-product-rail-section>
      <div class="ttt-product-section-head"><div><span>CURATED FOR YOU</span><h2>Featured Products</h2></div><div class="ttt-product-section-actions"><a href="/shop">View All</a><button type="button" data-rail-prev aria-label="Previous products"><i class="bi bi-arrow-left"></i></button><button type="button" data-rail-next aria-label="Next products"><i class="bi bi-arrow-right"></i></button></div></div>
      <div class="ttt-product-rail" data-product-rail><% featured.forEach(function(p) { %><div class="ttt-product-rail-item"><%- include('partials/product-card', { p, hideOfferButton: true }) %></div><% }); %></div>
    </article>
  <% } %>
</section>

<section class="ttt-confidence ttt-reveal">
  <span>TTT OUTFIT</span>
  <h2>Fashion created for confidence.</h2>
  <p>Thoughtful fits, premium fabrics and versatile pieces made for the way you live.</p>
  <a href="/shop">Explore the collection <i class="bi bi-arrow-right"></i></a>
</section>

<section class="ttt-designed">
  <div class="ttt-section-heading ttt-reveal"><span>OUR PROMISE</span><h2>Designed Around You</h2></div>
  <div class="ttt-designed-rail">
    <article class="ttt-designed-card ttt-reveal"><i class="bi bi-gem"></i><h3>Premium Quality</h3><p>Carefully selected materials with a refined finish.</p></article>
    <article class="ttt-designed-card ttt-reveal"><i class="bi bi-rulers"></i><h3>Confident Fits</h3><p>Modern silhouettes designed for comfort and movement.</p></article>
    <article class="ttt-designed-card ttt-reveal"><i class="bi bi-truck"></i><h3>Reliable Delivery</h3><p>Secure ordering and dependable delivery across Bangladesh.</p></article>
  </div>
</section>

<section class="ttt-newsletter ttt-reveal">
  <div class="ttt-newsletter-copy"><span>STAY CONNECTED</span><h2>Join the TTT Community</h2><p>Be first to hear about new drops, exclusive offers and style updates.</p></div>
  <form class="ttt-newsletter-form" action="/newsletter/subscribe" method="post" novalidate>
    <label class="sr-only" for="newsletterEmail">Email address</label>
    <input id="newsletterEmail" type="email" name="email" placeholder="Your email address" required autocomplete="email" aria-describedby="newsletterHint newsletterStatus">
    <button type="submit">Subscribe <i class="bi bi-arrow-right"></i></button>
    <small id="newsletterHint">By subscribing, you agree to receive TTT Outfit updates.</small>
    <span class="ttt-newsletter-status" id="newsletterStatus" aria-live="polite"></span>
  </form>
</section>

<%- include('partials/footer') %>
