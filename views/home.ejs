<%- include('partials/header') %>

<section class="hero-slider">

  <div
    class="hero-slide active"

      linear-gradient(
  90deg,
  rgba(0, 0, 0, 0.82) 0%,
  rgba(0, 0, 0, 0.58) 38%,
  rgba(0, 0, 0, 0.12) 75%
),
url('/hero-1.jpg');
  >
<div class="hero-slide hero-slide-one active">
 <div class="hero-content-wrap">
  <div class="container">
    <div class="hero-text">

      <span class="hero-kicker">
        TTT OUTFIT — NEW COLLECTION
      </span>

      <h1>
        Wear your
        <em>identity.</em>
      </h1>

      <p>
        Premium fabrics, confident fits and modern
        everyday fashion made for your lifestyle.
      </p>

      <div class="hero-actions">
        <a class="btn gold-btn" href="/shop">
          Shop Collection
        </a>

        <a class="btn outline-btn" href="#categories">
          Explore Categories
        </a>
      </div>

    </div>
  </div>
</div>

  <div
    class="hero-slide"

      linear-gradient(
        90deg,
        rgba(0,0,0,.80),
        rgba(0,0,0,.15)
      ),
url('/hero-2.jpg');
  >
<div class="hero-slide hero-slide-two">
<div class="hero-content-wrap">
  <div class="container">
    <div class="hero-text">

      <span class="hero-kicker">
        TTT OUTFIT — NEW COLLECTION
      </span>

      <h1>
        Wear your
        <em>identity.</em>
      </h1>

      <p>
        Premium fabrics, confident fits and modern
        everyday fashion made for your lifestyle.
      </p>

      <div class="hero-actions">
        <a class="btn gold-btn" href="/shop">
          Shop Collection
        </a>

        <a class="btn outline-btn" href="#categories">
          Explore Categories
        </a>
      </div>

    </div>
  </div>
</div>

  <button
    class="hero-arrow hero-prev"
    type="button"
    aria-label="Previous slide"
  >
    &#10094;
  </button>

  <button
    class="hero-arrow hero-next"
    type="button"
    aria-label="Next slide"
  >
    &#10095;
  </button>

  <div class="hero-dots">
  <button
    class="hero-dot active"
    type="button"
    aria-label="Go to slide 1"
  ></button>

  <button
    class="hero-dot"
    type="button"
    aria-label="Go to slide 2"
  ></button>
</div>

</section>

<section class="benefits-strip">
  <div class="container benefits-grid">

    <div class="benefit-item reveal">
      <span class="benefit-icon">✦</span>
      <div>
        <strong>Premium Quality</strong>
        <small>Carefully selected fabrics</small>
      </div>
    </div>

    <div class="benefit-item reveal">
      <span class="benefit-icon">৳</span>
      <div>
        <strong>Secure Payment</strong>
        <small>COD, bKash and Nagad</small>
      </div>
    </div>

    <div class="benefit-item reveal">
      <span class="benefit-icon">✓</span>
      <div>
        <strong>Easy Ordering</strong>
        <small>Simple and fast checkout</small>
      </div>
    </div>

    <div class="benefit-item reveal">
      <span class="benefit-icon">↻</span>
      <div>
        <strong>Order Support</strong>
        <small>Track orders from your account</small>
      </div>
    </div>

  </div>
</section>

<section class="section category-section" id="categories">
  <div class="container">

    <div class="section-title reveal">
      <span class="section-kicker">
        SHOP BY COLLECTION
      </span>

      <h2>Find your style</h2>

      <p>
        Explore premium everyday fashion from
        TTT Outfit.
      </p>
    </div>

    <div class="premium-category-grid">

      <a
        class="premium-category-card reveal"
        href="/shop?category=T-Shirts"
      >
        <img
          src="/category-tshirt.jpg"
          alt="TTT Outfit T-Shirts"
        >

        <div class="premium-category-overlay">
          <span class="category-label">
            TTT ESSENTIALS
          </span>

          <h3>T-Shirts</h3>

          <span class="category-shop-link">
            Shop collection
            <strong>→</strong>
          </span>
        </div>
      </a>

      <a
        class="premium-category-card reveal"
        href="/shop?category=Polo"
      >
        <img
          src="/category-polo.jpg"
          alt="TTT Outfit Polo Shirts"
        >

        <div class="premium-category-overlay">
          <span class="category-label">
            SMART CASUAL
          </span>

          <h3>Polo Shirts</h3>

          <span class="category-shop-link">
            Shop collection
            <strong>→</strong>
          </span>
        </div>
      </a>

      <a
  class="premium-category-card reveal"
  href="/shop?category=Drop%20Shoulder"
>
    <img
      src="/category-drop-shoulder.jpg"
      alt="TTT Outfit Drop Shoulder"
    >

    <div class="premium-category-overlay">
      <span class="category-label">
        STREETWEAR
      </span>

      <h3>Drop Shoulder</h3>

      <span class="category-shop-link">
        Shop collection
        <strong>→</strong>
      </span>
    </div>
</a>

      <a
        class="premium-category-card reveal"
        href="/shop?category=Jackets"
      >
        <img
          src="/category-jacket.jpg"
          alt="TTT Outfit Jackets"
        >

        <div class="premium-category-overlay">
          <span class="category-label">
            URBAN LAYERS
          </span>

          <h3>Jackets</h3>

          <span class="category-shop-link">
            Shop collection
            <strong>→</strong>
          </span>
        </div>
      </a>

    </div>

  </div>
</section>

<section class="promo-banner">
  <div class="container promo-content reveal">

    <div>
      <span class="section-kicker gold-text">
        TTT OUTFIT
      </span>

      <h2>
        Fashion created for
        <em>confidence.</em>
      </h2>

      <p>
        Build your everyday wardrobe with premium
        clothing designed for comfort and style.
      </p>
    </div>

    <a class="btn gold-btn" href="/shop">
      Discover the Collection
    </a>

  </div>
</section>

<section class="section">
  <div class="container">

    <div class="section-title reveal">
      <span class="section-kicker">
        WHY TTT OUTFIT
      </span>

      <h2>Designed around you</h2>
    </div>

    <div class="why-grid">

      <article class="why-card reveal">
        <span>01</span>
        <h3>Quality Fabrics</h3>
        <p>
          Materials selected for everyday comfort,
          durability and a premium feel.
        </p>
      </article>

      <article class="why-card reveal">
        <span>02</span>
        <h3>Modern Design</h3>
        <p>
          Clean, confident styles that work across
          casual and smart-casual occasions.
        </p>
      </article>

      <article class="why-card reveal">
        <span>03</span>
        <h3>Bangladesh Delivery</h3>
        <p>
          Convenient ordering and nationwide courier
          delivery support.
        </p>
      </article>

    </div>

  </div>
</section>

<section class="newsletter-section">
  <div class="container newsletter reveal">

    <div>
      <span class="section-kicker gold-text">
        STAY UPDATED
      </span>

      <h2>Join the TTT community</h2>

      <p>
        Get updates about new collections,
        promotions and exclusive offers.
      </p>
    </div>

    <form
      class="newsletter-form"
      onsubmit="event.preventDefault();"
    >
      <input
        type="email"
        placeholder="Enter your email address"
        required
      >

      <button class="btn gold-btn" type="submit">
        Subscribe
      </button>
    </form>

  </div>
</section>


<%- include('partials/footer') %>
