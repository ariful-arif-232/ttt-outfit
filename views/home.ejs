<%- include('partials/header') %>

<% const activeSlides = (sliders || []).length ? sliders : [{ desktopImage: '/hero-1.jpg', mobileImage: '/hero-1-mobile.jpg', subtitle: 'NEW COLLECTION', title: 'Wear Your Identity', description: 'Premium everyday fashion designed for confidence, comfort and modern life.', buttonText: 'Shop Now', buttonLink: '/shop', textPosition: 'left-center' }]; %>
<section class="ttt-hero" data-hero-slider aria-label="Featured collections">
  <div class="ttt-hero-track">
    <% activeSlides.forEach(function(slide, index) { %>
      <%
        const rawTextPosition = String(slide.textPosition || 'left-center').trim().toLowerCase();
        const textPositionAliases = {
          'center-left': 'left-center',
          'top-left': 'left-top',
          'bottom-left': 'left-bottom',
          'top-center': 'center-top',
          'bottom-center': 'center-bottom',
          'top-right': 'right-top',
          'bottom-right': 'right-bottom'
        };
        const allowedTextPositions = [
          'left-top', 'left-center', 'left-bottom',
          'center-top', 'center-center', 'center-bottom',
          'right-top', 'right-center', 'right-bottom'
        ];
        const normalizedTextPosition = textPositionAliases[rawTextPosition] || rawTextPosition;
        const heroTextPosition = allowedTextPositions.includes(normalizedTextPosition)
          ? normalizedTextPosition
          : 'left-center';
      %>
      <article class="ttt-hero-slide <%= index === 0 ? 'is-active' : '' %> ttt-position-<%= heroTextPosition %>" aria-hidden="<%= index === 0 ? 'false' : 'true' %>">
        <%
          const desktopImageUrl =
            (slide.desktopImage && slide.desktopImage.url)
              ? slide.desktopImage.url
              : (typeof slide.desktopImage === 'string' ? slide.desktopImage : '/hero-1.jpg');

          const mobileImageUrl =
            (slide.mobileImage && slide.mobileImage.url)
              ? slide.mobileImage.url
              : (typeof slide.mobileImage === 'string' ? slide.mobileImage : '');
        %>
        <picture>
          <% if (mobileImageUrl) { %>
            <source media="(max-width: 700px)" srcset="<%= mobileImageUrl %>">
          <% } %>
          <img
            src="<%= desktopImageUrl %>"
            alt="<%= slide.title || 'TTT Outfit collection' %>"
            <%= index === 0 ? 'fetchpriority="high"' : 'loading="lazy"' %>
          >
        </picture>
        <div class="ttt-hero-overlay"></div>
<% if (slide.description) { %>
  <p
    class="ttt-hero-side-description ttt-description-<%= slide.descriptionPosition || 'left' %>"
  >
    <%= slide.description %>
  </p>
<% } %>

<div class="ttt-hero-content">

  <% if (slide.subtitle) { %>
    <span class="ttt-eyebrow">
      <%= slide.subtitle %>
    </span>
  <% } %>

  <h1>
    <%= slide.title || 'Wear Your Identity' %>
  </h1>

  <% if (slide.buttonText) { %>
    <a
      class="ttt-primary-button"
      href="<%= slide.buttonLink || '/shop' %>"
    >
      <%= slide.buttonText %>
    </a>
  <% } %>

</div>
      </article>
    <% }); %>
  </div>
  <% if (activeSlides.length > 1) { %>
    <button class="ttt-hero-arrow ttt-hero-prev" type="button" aria-label="Previous slide"><i class="bi bi-arrow-left"></i></button>
    <button class="ttt-hero-arrow ttt-hero-next" type="button" aria-label="Next slide"><i class="bi bi-arrow-right"></i></button>
    <div class="ttt-hero-dots" role="tablist" aria-label="Choose slide">
      <% activeSlides.forEach(function(_, index) { %><button type="button" class="<%= index === 0 ? 'is-active' : '' %>" role="tab" aria-selected="<%= index === 0 ? 'true' : 'false' %>" tabindex="<%= index === 0 ? '0' : '-1' %>" aria-label="Go to slide <%= index + 1 %>"></button><% }); %>
    </div>
  <% } %>
</section>

<section class="ttt-showcase" id="categories">
<div class="ttt-section-heading ttt-reveal">
  <span class="ttt-ready-title" aria-label="Ready To Wear">
    <i style="--delay:0.05s">R</i>
    <i style="--delay:0.10s">E</i>
    <i style="--delay:0.15s">A</i>
    <i style="--delay:0.20s">D</i>
    <i style="--delay:0.25s">Y</i>

    <i class="ttt-ready-space">&nbsp;</i>

    <i style="--delay:0.30s">T</i>
    <i style="--delay:0.35s">O</i>

    <i class="ttt-ready-space">&nbsp;</i>

    <i style="--delay:0.40s">W</i>
    <i style="--delay:0.45s">E</i>
    <i style="--delay:0.50s">A</i>
    <i style="--delay:0.55s">R</i>
  </span>

  <h2>TOP COLLECTION</h2>
</div>
  <div class="ttt-showcase-grid">
    <% const showcase = (showcaseCategories || []).length ? showcaseCategories : [
      {name:'T-Shirt', image:'/category-tshirt.jpg', buttonText:'Explore Collection'},
      {name:'Polo Shirt', image:'/category-polo.jpg', buttonText:'Shop Polo'},
      {name:'Drop Shoulder T-Shirt', image:'/category-drop-shoulder.jpg', buttonText:'Discover Now'},
      {name:'Jacket', image:'/category-jacket.jpg', buttonText:'View Collection'}
    ]; %>
    <% showcase.forEach(function(cat) { %>
      <%
        const categoryImageUrl =
          (cat.image && cat.image.url)
            ? cat.image.url
            : (typeof cat.image === 'string'
                ? cat.image
                : (cat.imageUrl || '/ttt-logo.jpeg'));
      %>
      <a class="ttt-showcase-card ttt-reveal" href="/shop?category=<%= encodeURIComponent(cat.name) %>">
        <img
          src="<%= categoryImageUrl %>"
          alt="<%= cat.name %>"
          loading="lazy"
          decoding="async"
          data-image-fallback="/ttt-logo.jpeg"
        >
        <span class="ttt-showcase-shade"></span>
        <span class="ttt-showcase-copy"><strong><%= cat.name %></strong><em><%= cat.buttonText || 'Shop Now' %> <i class="bi bi-arrow-right"></i></em></span>
      </a>
    <% }); %>
  </div>
</section>

<section class="ttt-category-rails" aria-label="Men's collections">
  <%
    const allCategorySections = Array.isArray(categorySections) ? categorySections : [];
    const groupRules = [
      { name: "Men's Top Wear", keywords: ['top wear','t-shirt','tshirt','polo','shirt','panjabi','jersey','tank top'] },
      { name: "Men's Bottom Wear", keywords: ['bottom wear','jeans','pants','pant','trouser','cargo','shorts','jogger'] },
      { name: "Men's Outer Wear", keywords: ['outer wear','outerwear','hoodie','jacket','blazer','sweater','coat','windbreaker'] }
    ];
    const groupedSections = groupRules.map(group => {
      const products = [];
      const seen = new Set();
      allCategorySections.forEach(section => {
        const categoryName = String(section?.category?.name || '').toLowerCase();
        if (group.keywords.some(keyword => categoryName.includes(keyword))) {
          (section.products || []).forEach(product => {
            const key = String(product?._id || product?.slug || product?.name || '');
            if (key && !seen.has(key)) { seen.add(key); products.push(product); }
          });
        }
      });
      return { name: group.name, products };
    });
  %>

<% groupedSections.forEach(function(section) { if (section.products.length) { %>

  <article
    class="ttt-product-section ttt-reveal"
    data-product-rail-section
  >

    <div class="ttt-product-section-head">

      <div>
        <span>TTT OUTFIT COLLECTION</span>
        <h2><%= section.name %></h2>
      </div>

      <div class="ttt-product-section-actions">

        <a href="/shop">
          View All
        </a>

        <button
          type="button"
          data-rail-prev
          aria-label="Previous products"
        >
          <i class="bi bi-arrow-left"></i>
        </button>

        <button
          type="button"
          data-rail-next
          aria-label="Next products"
        >
          <i class="bi bi-arrow-right"></i>
        </button>

      </div>
    </div>

    <div
      class="swiper ttt-product-swiper"
      data-product-swiper
    >

      <div class="swiper-wrapper">

        <% section.products.forEach(function(p) { %>

          <div class="swiper-slide ttt-product-rail-item">

            <%- include('partials/product-card', {
              p,
              hideOfferButton: true
            }) %>

          </div>

        <% }); %>

      </div>
    </div>

  </article>

<% } }); %>


<%
  const hasGroupedProducts =
    groupedSections.some(
      section => section.products.length
    );
%>

<%
  if (
    !hasGroupedProducts &&
    (featured || []).length
  ) {
%>

  <article
    class="ttt-product-section ttt-reveal"
    data-product-rail-section
  >

    <div class="ttt-product-section-head">

      <div>
        <span>CURATED FOR YOU</span>
        <h2>Men's Collection</h2>
      </div>

    </div>

    <div
      class="swiper ttt-product-swiper"
      data-product-swiper
    >

      <div class="swiper-wrapper">

        <% featured.forEach(function(p) { %>

          <div class="swiper-slide ttt-product-rail-item">

            <%- include('partials/product-card', {
              p,
              hideOfferButton: true
            }) %>

          </div>

        <% }); %>

      </div>
    </div>

  </article>

<% } %>

</section>

<div class="ttt-quick-cart-backdrop" data-quick-cart-backdrop hidden></div>
<aside class="ttt-quick-cart-drawer" data-quick-cart-drawer aria-hidden="true" aria-label="Add product to cart">
  <button class="ttt-quick-cart-close" type="button" data-quick-cart-close aria-label="Close"><i class="bi bi-x-lg"></i></button>
  <div class="ttt-quick-cart-product">
    <img src="/ttt-logo.jpeg" alt="" data-drawer-image>
    <div>
      <h3 data-drawer-name>Product</h3>
      <div class="ttt-drawer-price"><strong data-drawer-price></strong><del data-drawer-compare></del></div>
      <div class="ttt-drawer-rating"><span>★</span> <strong data-drawer-rating>0.0</strong> <small data-drawer-reviews></small></div>
      <p class="ttt-drawer-stock" data-drawer-stock></p>
    </div>
  </div>
  <form method="post" action="/cart/add" data-quick-cart-form>
    <input type="hidden" name="productId" data-drawer-product-id>
    <input type="hidden" name="color" data-drawer-color>
    <input type="hidden" name="size" data-drawer-size>
    <div class="ttt-drawer-option" data-drawer-color-wrap><span>Color</span><div data-drawer-colors></div></div>
    <div class="ttt-drawer-option" data-drawer-size-wrap><span>Size</span><div data-drawer-sizes></div></div>
    <div class="ttt-drawer-quantity-row">
      <span>Quantity</span>
      <div class="ttt-drawer-quantity"><button type="button" data-qty-minus>−</button><input type="number" name="quantity" value="1" min="1" data-drawer-qty><button type="button" data-qty-plus>+</button></div>
    </div>
    <button class="ttt-drawer-submit" type="submit">Add to Cart</button>
  </form>
</aside>

<section class="ttt-confidence ttt-reveal">
  <span>TTT OUTFIT</span>
  <h2>Fashion created for confidence.</h2>
  <p>Thoughtful fits, premium fabrics and versatile pieces made for the way you live.</p>
  <a href="/shop">Explore the collection <i class="bi bi-arrow-right"></i></a>
</section>

<section class="ttt-designed ttt-reveal">

  <div class="ttt-section-heading">
    <span>OUR PROMISE</span>
    <h2>Designed Around You</h2>
  </div>

  <div class="ttt-designed-compact">

    <div class="ttt-designed-item">
      <i class="bi bi-gem"></i>

      <div>
        <h3>Premium Quality</h3>
        <p>Selected premium materials.</p>
      </div>
    </div>

    <div class="ttt-designed-item">
      <i class="bi bi-rulers"></i>

      <div>
        <h3>Confident Fits</h3>
        <p>Comfortable modern fitting.</p>
      </div>
    </div>

    <div class="ttt-designed-item">
      <i class="bi bi-truck"></i>

      <div>
        <h3>Reliable Delivery</h3>
        <p>Delivery across Bangladesh.</p>
      </div>
    </div>

  </div>

</section>

<section class="ttt-newsletter ttt-reveal">
  <div class="ttt-newsletter-copy"><span>STAY CONNECTED</span><h2>Join the TTT Community</h2><p>Be first to hear about new drops, exclusive offers and style updates.</p></div>
  <form class="ttt-newsletter-form" action="/newsletter/subscribe" method="post" novalidate>
    <label class="sr-only" for="newsletterEmail">Email address</label>
    <input id="newsletterEmail" type="email" name="email" placeholder="Your email address" required autocomplete="email" aria-describedby="newsletterHint newsletterStatus">
    <button type="submit">Subscribe <i class="bi bi-arrow-right"></i></button>
    <small id="newsletterHint">By subscribing, you agree to receive TTT Outfit updates.</small>
    <span class="ttt-newsletter-status" id="newsletterStatus" aria-live="polite"></span>
  </form>
</section>
<script>
  document.addEventListener("DOMContentLoaded", function () {
    const readyTitle = document.querySelector(".ttt-ready-title");

    if (!readyTitle) return;

    const readyObserver = new IntersectionObserver(
      function (entries, observer) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            readyTitle.classList.add("ttt-ready-show");
            observer.unobserve(entry.target);
          }
        });
      },
      {
        threshold: 0.35
      }
    );

    readyObserver.observe(readyTitle);
  });
</script>
<%- include('partials/footer') %>
