<%- include('partials/header') %><section class="section"><div class="container"><h1>Welcome, <%= user.name %></h1><div class="two-col"><div><h2>Recent orders</h2><% if(!orders.length){ %><div class="panel">No orders yet.</div><% } orders.forEach(o=>{ %><a class="order-card" style="display:block" href="/orders/<%= o._id %>"><strong><%= o.orderNumber %></strong><span style="float:right" class="status"><%= o.status %></span><p class="small"><%= new Date(o.createdAt).toLocaleDateString() %> · ৳<%= money(o.total) %></p></a><% }) %></div><aside class="panel"><h2>Profile</h2><p><strong><%= user.name %></strong></p><p><%= user.email %></p><p><%= user.phone %></p><a href="/orders"><u>View all orders</u></a></aside></div></div></section><%- include('partials/footer') %>
