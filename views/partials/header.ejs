  <img
    class="brand-logo"
    src="/ttt-logo.jpeg"
    alt="TTT Outfit logo"
  >

  <span>
    TTT <strong>OUTFIT</strong>
  </span>
</a>


<!-- Mobile navigation icons -->

<div class="mobile-header-actions">

  <!-- Search -->

  <button
    class="mobile-header-icon mobile-search-toggle"
    id="mobileSearchToggle"
    type="button"
    aria-label="Search products"
    aria-expanded="false"
    aria-controls="mobileSearchPanel"
  >
    <i class="bi bi-search"></i>
  </button>


  <!-- Shop -->

  <a
    class="mobile-header-icon"
    href="/shop"
    aria-label="Shop"
  >
    <i class="bi bi-bag"></i>
  </a>


  <!-- Cart -->

  <a
    class="mobile-header-icon mobile-header-cart"
    href="/cart"
    aria-label="Cart"
  >
    <i class="bi bi-cart3"></i>

    <span
      class="mobile-header-badge"
      data-cart-count
    >
      <%= cartCount %>
    </span>
  </a>


  <!-- Menu -->

  <button
    class="mobile-menu-button"
    id="mobileMenuButton"
    type="button"
    aria-label="Open navigation menu"
    aria-expanded="false"
    aria-controls="navLinks"
  >
    <span></span>
    <span></span>
    <span></span>
  </button>

</div>
<nav class="nav-links" id="navLinks">

<div class="mobile-menu-brand">
  <img
