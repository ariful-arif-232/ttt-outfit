<article class="product-card"><a href="/product/<%= p.slug %>"><img src="<%= p.images?.[0]?.url || 'https://via.placeholder.com/600x750?text=TTT+Outfit' %>" alt="<%= p.name %>"></a><div class="product-info"><span class="badge"><%= p.category %></span><h3><a href="/product/<%= p.slug %>"><%= p.name %></a></h3><span class="price">৳<%= money(p.price) %></span><% if(p.compareAtPrice>p.price){ %><span class="old-price">৳<%= money(p.compareAtPrice) %></span><% } %><p class="small"><%= p.stock>0 ? `${p.stock} in stock` : 'Out of stock' %></p></div></article>
