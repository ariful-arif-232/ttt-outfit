<%
const firstVariant =
  p.variants?.find(
    variant => Number(variant.stock || 0) > 0
  ) ||
  p.variants?.[0] ||
  null;

  const mainImage =
    firstVariant?.images?.[0]?.url ||
    p.images?.[0]?.url ||
    'https://via.placeholder.com/700x875?text=TTT+Outfit';

  const secondImage =
    firstVariant?.images?.[1]?.url ||
    p.images?.[1]?.url ||
    mainImage;

  const hasDiscount =
    Number(p.compareAtPrice || 0) >
    Number(p.price || 0);

  const discountPercent =
    hasDiscount && Number(p.compareAtPrice) > 0
      ? Math.round(
          (
            (
              Number(p.compareAtPrice) -
              Number(p.price)
            ) /
            Number(p.compareAtPrice)
          ) * 100
        )
      : 0;

  const productSizes =
    firstVariant?.sizes?.length
      ? firstVariant.sizes
      : Array.isArray(p.sizes)
        ? p.sizes
        : [];

  const productColors =
    p.variants?.length
      ? p.variants
          .map(variant => variant.color)
          .filter(Boolean)
      : Array.isArray(p.colors)
        ? p.colors
        : [];

  const productStock =
    p.variants?.length
      ? p.variants.reduce(
          (total, variant) =>
            total + Number(variant.stock || 0),
          0
        )
      : Number(p.stock || 0);

  const selectedSize =
    productSizes[0] || 'One Size';

  const selectedColor =
    firstVariant?.color ||
    productColors[0] ||
    'Default';
%>

<article class="professional-product-card">

  <div class="product-image-wrap">

    <a
      class="product-image-link"
      href="/product/<%= p.slug %>"
      aria-label="View <%= p.name %>"
    >

      <img
        class="product-primary-image"
        src="<%= mainImage %>"
        alt="<%= p.name %>"
        loading="lazy"
      >

<img
  class="product-secondary-image"
  src="<%= secondImage %>"
  alt="<%= p.name %> alternate view"
  loading="lazy"
>

    </a>


    <!-- Discount and stock badges -->

    <div class="product-badges">

      <% if (hasDiscount) { %>

        <span class="sale-badge">
          -<%= discountPercent %>%
        </span>

      <% } %>


      <% if (productStock < 1) { %>

        <span class="sold-out-badge">
          Sold Out
        </span>

      <% } else if (productStock <= 5) { %>

        <span class="low-stock-badge">
          Only <%= productStock %> left
        </span>

      <% } %>

    </div>


    <!-- Quick view and wishlist -->

    <div class="product-hover-actions">

      <a
        class="product-quick-view-button"
        href="/product/<%= p.slug %>"
        aria-label="View <%= p.name %> details"
        title="View product"
      >
        <i
          class="bi bi-eye"
          aria-hidden="true"
        ></i>
      </a>


      <button
        class="product-wishlist-button"
        type="button"
        data-product-id="<%= p._id %>"
        data-product-name="<%= p.name %>"
        data-product-slug="<%= p.slug %>"
        data-product-image="<%= mainImage %>"
        data-product-price="<%= p.price %>"
        aria-label="Add <%= p.name %> to wishlist"
        aria-pressed="false"
        title="Add to Wishlist"
      >
        <span>♡</span>
      </button>

    </div>


    <!-- Add to cart -->

    <% if (productStock > 0) { %>

<form
  class="quick-cart-form"
  method="post"
  action="/cart/add"
>

        <input
          type="hidden"
          name="productId"
          value="<%= p._id %>"
        >

        <input
          type="hidden"
          name="quantity"
          value="1"
        >

<input
  type="hidden"
  name="size"
  value="<%= selectedSize %>"
  data-selected-size
>
<input
  type="hidden"
  name="color"
  value="<%= selectedColor %>"
  data-selected-color
>

        <button
          type="submit"
          aria-label="Add <%= p.name %> to cart"
        >

          <i
            class="bi bi-cart-plus"
            aria-hidden="true"
          ></i>

          <span>Add to cart</span>

        </button>

      </form>

    <% } %>

  </div>


  <!-- Product information -->

  <div class="professional-product-info">

    <div class="product-meta-row">

      <span class="product-category">
        <%= p.category %>
      </span>

      <% if (p.gender) { %>

        <span class="product-gender">
          <%= p.gender %>
        </span>

      <% } %>

    </div>


    <h3>

      <a href="/product/<%= p.slug %>">
        <%= p.name %>
      </a>

    </h3>


    <!-- Rating and sold count -->

    <div class="product-rating-row">

      <div
        class="product-rating"
        aria-label="<%= Number(p.ratingAverage || 0).toFixed(1) %> out of 5"
      >

        <span>★</span>

        <strong>
          <%= Number(p.ratingAverage || 0).toFixed(1) %>
        </strong>

      </div>


      <% if (Number(p.soldCount || 0) > 0) { %>

        <span class="product-sold-count">
          <%= p.soldCount %> sold
        </span>

      <% } %>

    </div>


    <!-- Price -->

    <div class="product-price-row">

      <span class="product-current-price">
        ৳<%= money(p.price) %>
      </span>

      <% if (hasDiscount) { %>

        <span class="product-compare-price">
          ৳<%= money(p.compareAtPrice) %>
        </span>

      <% } %>

    </div>


  


<!-- Color preview -->

<% if (p.variants?.length) { %>

  <div
    class="product-color-preview"
    data-color-options
  >

    <% p.variants.forEach((variant) => { %>

      <button
        type="button"
        class="product-color-option <%= variant === firstVariant ? 'active' : '' %>"
        data-color="<%= variant.color %>"
        data-image="<%= variant.images?.[0]?.url || mainImage %>"
        data-second-image="<%= variant.images?.[1]?.url || variant.images?.[0]?.url || mainImage %>"
        data-sizes='<%- JSON.stringify(variant.sizes || []) %>'
        data-stock="<%= Number(variant.stock || 0) %>"
        aria-label="Select <%= variant.color %>"
        title="<%= variant.color %>"
        style="
          --swatch-color:
          <%= variant.colorHex || '#cccccc' %>;
        "
      ></button>

    <% }) %>

  </div>

<% } %>


    <!-- Available sizes -->

    <% if (productSizes.length) { %>

<div class="product-size-list" data-size-options>

  <% productSizes.forEach((size, index) => { %>

    <button
      type="button"
      class="product-size-option <%= index === 0 ? 'active' : '' %>"
      data-size="<%= size %>"
    >
      <%= size %>
    </button>

  <% }) %>

</div>

    <% } %>
 

<!-- Card footer -->

<div class="product-card-footer product-card-footer-offer">

  <div class="product-footer-left">

    <div class="product-sale-types">

      <span>
        <i
          class="bi bi-box-seam"
          aria-hidden="true"
        ></i>

        Wholesale
      </span>

      <span class="sale-type-separator">
        •
      </span>

      <span>
        <i
          class="bi bi-bag"
          aria-hidden="true"
        ></i>

        Retail
      </span>

    </div>

    <span
      class="
        product-stock-status
        <%= productStock > 0
          ? 'available'
          : 'unavailable'
        %>
      "
    >

      <i></i>

      <%= productStock > 0
        ? 'Available'
        : 'Out of stock'
      %>

    </span>

  </div>


<div class="product-footer-right">

  <button
    class="product-offer-button"
    type="button"
    data-offer-url="/shop"
    aria-label="Get 20% wholesale offer"
  >

    <i
      class="bi bi-tags-fill offer-tag-icon"
      aria-hidden="true"
    ></i>

    <span class="offer-text">

      <span class="offer-word">
        GET
      </span>

      <span class="offer-percent">
        20%
      </span>

      <span class="offer-word">
        OFF
      </span>

    </span>

  </button>

</div>
</div>

  </div>

</article>
