<%
  const firstVariant = p.variants?.find(v => Number(v.stock || 0) > 0) || p.variants?.[0] || null;
  const mainImage = firstVariant?.mainImage?.url || firstVariant?.images?.[0]?.url || p.images?.[0]?.url || 'https://via.placeholder.com/700x875?text=TTT+Outfit';
  const secondImage = firstVariant?.hoverImage?.url || firstVariant?.images?.[1]?.url || firstVariant?.galleryImages?.[0]?.url || p.images?.[1]?.url || mainImage;
  const hasDiscount = Number(p.compareAtPrice || 0) > Number(p.price || 0);
  const discountPercent = hasDiscount ? Math.round(((Number(p.compareAtPrice) - Number(p.price)) / Number(p.compareAtPrice)) * 100) : 0;
  const productStock = p.variants?.length ? p.variants.reduce((sum, v) => sum + Number(v.stock || 0), 0) : Number(p.stock || 0);
  const variantsForDrawer = (p.variants || []).map(v => ({
    color: v.color || 'Default',
    colorHex: v.colorHex || '#d7d7d7',
    stock: Number(v.stock || 0),
    sizes: Array.isArray(v.sizes) ? v.sizes : [],
    image: v.mainImage?.url || v.images?.[0]?.url || mainImage
  }));
  const fallbackSizes = Array.isArray(p.sizes) ? p.sizes : [];
  const fallbackColors = Array.isArray(p.colors) ? p.colors : [];
  const drawerProduct = {
    id: String(p._id), slug: p.slug, name: p.name, image: mainImage,
    price: Number(p.price || 0), compareAtPrice: Number(p.compareAtPrice || 0),
    rating: Number(p.ratingAverage || 0), reviewCount: Number(p.ratingCount || p.reviewCount || 0),
    stock: productStock, variants: variantsForDrawer, sizes: fallbackSizes, colors: fallbackColors
  };
%>

<article class="professional-product-card ttt-compact-product-card">
  <div class="product-image-wrap">
    <a class="product-image-link" href="/product/<%= p.slug %>" aria-label="View <%= p.name %>">
      <img class="product-primary-image" src="<%= mainImage %>" alt="<%= p.name %>" loading="lazy">
      <img class="product-secondary-image" src="<%= secondImage %>" alt="<%= p.name %> alternate view" loading="lazy">
    </a>

    <% if (hasDiscount) { %>
      <span class="sale-badge ttt-card-discount">-<%= discountPercent %>%</span>
    <% } %>

    <button
      class="product-wishlist-button ttt-card-wishlist"
      type="button"
      data-product-id="<%= p._id %>"
      data-product-name="<%= p.name %>"
      data-product-slug="<%= p.slug %>"
      data-product-image="<%= mainImage %>"
      data-product-price="<%= p.price %>"
      aria-label="Add <%= p.name %> to wishlist"
      aria-pressed="false"
      title="Wishlist"
    ><span>♡</span></button>

    <div class="ttt-card-bottom-icons" aria-label="Product actions">
      <a class="ttt-card-buy-icon" href="/product/<%= p.slug %>" aria-label="View and buy <%= p.name %>" title="Buy now">
        <i class="bi bi-bag-check" aria-hidden="true"></i>
      </a>
      <% if (productStock > 0) { %>
        <button
          class="ttt-card-cart-icon"
          type="button"
          data-quick-cart-trigger
          data-product='<%= JSON.stringify(drawerProduct) %>'
          aria-label="Choose options and add <%= p.name %> to cart"
          title="Add to cart"
        ><i class="bi bi-cart-plus" aria-hidden="true"></i></button>
      <% } else { %>
        <button class="ttt-card-cart-icon is-disabled" type="button" disabled aria-label="Out of stock" title="Out of stock">
          <i class="bi bi-cart-x" aria-hidden="true"></i>
        </button>
      <% } %>
    </div>
  </div>

  <div class="professional-product-info ttt-compact-product-info">
    <h3><a href="/product/<%= p.slug %>"><%= p.name %></a></h3>
    <div class="product-price-row">
      <span class="product-current-price">৳<%= money(p.price) %></span>
      <% if (hasDiscount) { %><span class="product-compare-price">৳<%= money(p.compareAtPrice) %></span><% } %>
    </div>
  </div>
</article>
