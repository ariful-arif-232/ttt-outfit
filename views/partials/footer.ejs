<script>
document.addEventListener('click', event => {
  const colorButton =
    event.target.closest('.product-color-option');

  if (colorButton) {
    const card =
      colorButton.closest('.professional-product-card');

    if (!card) return;

    card
      .querySelectorAll('.product-color-option')
      .forEach(button => {
        button.classList.remove('active');
      });

    colorButton.classList.add('active');

    const colorInput =
      card.querySelector('[data-selected-color]');

    if (colorInput) {
      colorInput.value =
        colorButton.dataset.color || '';
    }

const mainImage =
  card.querySelector('.product-primary-image');

const secondImage =
  card.querySelector('.product-secondary-image');

if (
  mainImage &&
  colorButton.dataset.image
) {
  mainImage.src =
    colorButton.dataset.image;
}

if (
  secondImage &&
  colorButton.dataset.secondImage
) {
  secondImage.src =
    colorButton.dataset.secondImage;
}

    let sizes = [];

    try {
      sizes = JSON.parse(
        colorButton.dataset.sizes || '[]'
      );
    } catch {
      sizes = [];
    }

    const sizeContainer =
      card.querySelector('[data-size-options]');

    const sizeInput =
      card.querySelector('[data-selected-size]');

    if (sizeContainer) {
      sizeContainer.innerHTML = '';

      sizes.forEach((size, index) => {
        const button =
          document.createElement('button');

        button.type = 'button';
        button.className =
          'product-size-option' +
          (index === 0 ? ' active' : '');

        button.dataset.size = size;
        button.textContent = size;

        sizeContainer.appendChild(button);
      });
    }

const selectedStock =
  Number(
    colorButton.dataset.stock || 0
  );

const cartForm =
  card.querySelector('.quick-cart-form');

const addButton =
  cartForm?.querySelector(
    'button[type="submit"]'
  );

if (addButton) {
  addButton.disabled =
    selectedStock < 1;

  const buttonText =
    addButton.querySelector('span');

  if (buttonText) {
    buttonText.textContent =
      selectedStock > 0
        ? 'Add to cart'
        : 'Out of stock';
  }
}
    return;
  }

  const sizeButton =
    event.target.closest('.product-size-option');

  if (sizeButton) {
    const card =
      sizeButton.closest('.professional-product-card');

    if (!card) return;

    card
      .querySelectorAll('.product-size-option')
      .forEach(button => {
        button.classList.remove('active');
      });

    sizeButton.classList.add('active');

    const sizeInput =
      card.querySelector('[data-selected-size]');

    if (sizeInput) {
      sizeInput.value =
        sizeButton.dataset.size || '';
    }
  }
});
</script>

