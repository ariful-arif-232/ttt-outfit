<%- include('partials/header') %>

<section class="auth-page-section">

  <div class="container auth-page-container">

    <div class="auth-premium-card">

      <aside class="auth-brand-panel">

        <div class="auth-brand-content">

          <a href="/" class="auth-logo-link">
            <img
              src="/ttt-logo.jpeg"
              alt="TTT Outfit"
            >

            <span>
              TTT <strong>OUTFIT</strong>
            </span>
          </a>

          <span class="auth-kicker">
            ACCOUNT RECOVERY
          </span>

          <h1>
            Forgot Your
            <em>Password?</em>
          </h1>

          <p>
            Enter your registered email address.
            We will send you a secure password reset link.
          </p>

        </div>

      </aside>


      <div class="auth-form-panel">

        <header class="auth-form-header">

          <span class="section-kicker">
            RESET PASSWORD
          </span>

          <h2>Find your account</h2>

          <p>
            The reset link will remain valid for 30 minutes.
          </p>

        </header>


        <form
          class="premium-auth-form"
          method="post"
          action="/forgot-password"
        >

          <div class="field">

            <label for="forgotEmail">
              Email Address
            </label>

            <div class="auth-input-wrap">

              <i class="bi bi-envelope"></i>

              <input
                id="forgotEmail"
                type="email"
                name="email"
                placeholder="Enter your registered email"
                autocomplete="email"
                required
              >

            </div>

          </div>


          <button
            class="btn auth-submit-button"
            type="submit"
          >
            Send Reset Link
            <i class="bi bi-send"></i>
          </button>

        </form>


        <p class="auth-switch-message">

          Remember your password?

          <a href="/auth?tab=login">
            Login here
          </a>

        </p>


        <div class="auth-security-note">

          <i class="bi bi-shield-check"></i>

          <span>
            For security, we do not reveal whether
            an email address is registered.
          </span>

        </div>

      </div>

    </div>

  </div>

</section>

<%- include('partials/footer') %>
