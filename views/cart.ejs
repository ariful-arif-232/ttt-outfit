<%- include('partials/header') %><section class="section"><div class="container"><h1>Your cart</h1><% if(!cart.length){ %><div class="panel"><p>Your cart is empty.</p><a class="btn" href="/shop">Start shopping</a></div><% } else { %><div class="two-col"><div class="panel"><% cart.forEach((i,index)=>{ %><div class="cart-row"><img src="<%= i.image %>"><div><strong><%= i.name %></strong><p class="small"><%= i.size %> / <%= i.color %></p></div><form method="post" action="/cart/update"><input type="hidden" name="index" value="<%= index %>"><input style="width:80px;padding:8px" type="number" name="quantity" value="<%= i.quantity %>" min="0"><button>Update</button></form><strong>৳<%= money(i.price*i.quantity) %></strong><form method="post" action="/cart/remove"><input type="hidden" name="index" value="<%= index %>"><button>Remove</button></form></div><% }) %></div><aside class="panel"><h2>Summary</h2><p>Subtotal <strong style="float:right">৳<%= money(subtotal) %></strong></p><p class="small">Delivery is calculated at checkout. Free above ৳3,000.</p><a class="btn" style="width:100%" href="/checkout">Checkout</a></aside></div><% } %></div></section><%- include('partials/footer') %>
