<%- include('partials/header') %><section class="section"><div class="container two-col"><div class="panel"><h1><%= order.orderNumber %></h1><p>Status: <strong><%= order.status %></strong> · Payment: <strong><%= order.paymentStatus %></strong></p><% order.items.forEach(i=>{ %><div class="cart-row"><img src="<%= i.image %>"><div><strong><%= i.name %></strong><p class="small"><%= i.size %> / <%= i.color %> · Qty <%= i.quantity %></p></div><strong>৳<%= money(i.lineTotal) %></strong></div><% }) %></div><aside class="panel"><h2>Delivery</h2><p><%= order.shippingAddress.address %><br><%= order.shippingAddress.city %> <%= order.shippingAddress.postalCode %></p><h2>Total</h2><p>Subtotal <span style="float:right">৳<%= money(order.subtotal) %></span></p><p>Delivery <span style="float:right">৳<%= money(order.deliveryFee) %></span></p><hr><p class="price">৳<%= money(order.total) %></p></aside></div></section><%- include('partials/footer') %>
