<%
  const fallbackImage =
    'https://via.placeholder.com/800x1000?text=TTT+Outfit';

  const variants =
    product.variants?.length
      ? product.variants
      : [
          {
            color:
              product.colors?.[0] || 'Default',

            colorHex: '#cccccc',

            stock:
              Number(product.stock || 0),

            sizes:
              product.sizes?.length
                ? product.sizes
                : ['One Size'],

            images:
              product.images?.length
                ? product.images
                : [{ url: fallbackImage }]
          }
        ];

  const firstVariant = variants[0];

  const variantJson =
    JSON.stringify(variants)
      .replace(/</g, '\\u003c');

  const rating =
    Number(product.ratingAverage || 0);

  const soldCount =
    Number(product.soldCount || 0);

  const totalStock =
    variants.reduce(
      (total, variant) =>
        total + Number(variant.stock || 0),
      0
    );

  const hasDiscount =
    Number(product.compareAtPrice) >
    Number(product.price);

  const discountPercent =
    hasDiscount && Number(product.compareAtPrice) > 0
      ? Math.round(
          (
            (
              Number(product.compareAtPrice) -
              Number(product.price)
            ) /
            Number(product.compareAtPrice)
          ) * 100
        )
      : 0;
%>

<%- include('partials/header') %>

<section class="section professional-product-page">

  <div class="container">

    <!-- Breadcrumb -->

    <nav
      class="product-breadcrumb"
      aria-label="Breadcrumb"
    >
      <a href="/">Home</a>
      <span>›</span>

      <a href="/shop">Shop</a>
      <span>›</span>

      <a
        href="/shop?category=<%= encodeURIComponent(product.category) %>"
      >
        <%= product.category %>
      </a>

      <span>›</span>
      <strong><%= product.name %></strong>
    </nav>


    <div class="product-detail-layout">

      <!-- ==========================
           PRODUCT GALLERY
      =========================== -->

      <div class="product-gallery">

        <div
          class="product-thumbnail-list"
          id="productThumbnailList"
        >
          <% firstVariant.images.forEach((image, index) => { %>

            <button
              class="product-thumbnail
                <%= index === 0 ? 'active' : '' %>"
              type="button"
              data-image="<%= image.url %>"
              aria-label="View image <%= index + 1 %>"
            >
              <img
                src="<%= image.url %>"
                alt="<%= product.name %> image <%= index + 1 %>"
                loading="<%= index === 0 ? 'eager' : 'lazy' %>"
              >
            </button>

          <% }) %>
        </div>


        <div
          class="product-main-image-wrap"
          id="productImageZoomArea"
        >
          <img
            class="main-image"
            id="productMainImage"
            src="<%= firstVariant.images?.[0]?.url || fallbackImage %>"
            alt="<%= product.name %>"
          >

          <div class="product-gallery-badges">

            <% if (hasDiscount) { %>
              <span class="product-detail-sale">
                -<%= discountPercent %>%
              </span>
            <% } %>

            <% if (totalStock > 0 && totalStock <= 5) { %>
              <span class="product-detail-low-stock">
                Low stock
              </span>
            <% } %>

          </div>

          <button
            class="product-zoom-button"
            id="productZoomButton"
            type="button"
            aria-label="View full-size image"
            title="View full-size image"
          >
            ⛶
          </button>
        </div>

      </div>


      <!-- ==========================
           PRODUCT INFORMATION
      =========================== -->

      <div class="product-detail-info">

        <div class="product-title-top">

          <span class="section-kicker">
            <%= product.category %>
          </span>

          <button
           class="product-page-wishlist product-wishlist-button"
            id="productPageWishlist"
            type="button"
            data-product-id="<%= product._id %>"
            data-product-name="<%= product.name %>"
            data-product-slug="<%= product.slug %>"
            data-product-image="<%= firstVariant.images?.[0]?.url || fallbackImage %>"
            data-product-price="<%= product.price %>"
            aria-label="Add product to wishlist"
            title="Add to wishlist"
          >
            <span>♡</span>
          </button>

        </div>


        <h1><%= product.name %></h1>


        <!-- Rating / sold / viewing -->

        <div class="product-social-proof">

          <div class="product-detail-rating">
            <span class="rating-star">★</span>

            <strong>
              <%= rating.toFixed(1) %>
            </strong>

            <small>
              <%= rating > 0
                ? 'Customer rating'
                : 'Not rated yet'
              %>
            </small>
          </div>

          <% if (soldCount > 0) { %>
            <span class="product-sold-proof">
              ✓ <%= soldCount %> sold
            </span>
          <% } %>

          <span class="product-viewing-proof">
  <i></i>

  <span id="productViewingCount">
    <%= viewerCount %>
    <%= viewerCount === 1
      ? 'person viewing'
      : 'people viewing'
    %>
  </span>
</span>
        </div>


        <!-- Price -->

        <div class="product-detail-price">

          <strong>
            ৳<%= money(product.price) %>
          </strong>

          <% if (hasDiscount) { %>
            <del>
              ৳<%= money(product.compareAtPrice) %>
            </del>

            <span class="product-price-saving">
              Save ৳<%=
                money(
                  Number(product.compareAtPrice) -
                  Number(product.price)
                )
              %>
            </span>
          <% } %>

        </div>


        <!-- Short description -->

        <div class="product-description">
          <p><%= product.description %></p>
        </div>


        <!-- Product meta -->

        <div class="product-meta">

          <span>
            <strong>SKU:</strong>
            <%= product.sku %>
          </span>

          <span>
            <strong>Material:</strong>
            <%= product.material || 'Not specified' %>
          </span>

          <span>
            <strong>Gender:</strong>
            <%= product.gender || 'Unisex' %>
          </span>

        </div>


        <!-- Cart form -->

        <form
          method="post"
          action="/cart/add"
          id="productCartForm"
        >

          <input
            type="hidden"
            name="productId"
            value="<%= product._id %>"
          >

          <input
            type="hidden"
            name="color"
            id="selectedColor"
            value="<%= firstVariant.color %>"
          >

          <input
            type="hidden"
            name="size"
            id="selectedSize"
            value="<%= firstVariant.sizes?.[0] || 'One Size' %>"
          >


          <!-- Color -->

          <div class="product-option-group">

            <div class="product-option-heading">

              <strong>Choose color</strong>

              <span id="selectedColorLabel">
                <%= firstVariant.color %>
              </span>

            </div>

            <div class="product-color-options">

              <% variants.forEach((variant, index) => { %>

                <button
                  class="product-color-option
                    <%= index === 0 ? 'active' : '' %>"
                  type="button"
                  data-variant-index="<%= index %>"
                  title="<%= variant.color %>"
                  aria-label="Select <%= variant.color %>"
                >
                  <span
                    style="background:
                      <%= variant.colorHex || '#cccccc' %>;"
                  ></span>

                  <small><%= variant.color %></small>
                </button>

              <% }) %>

            </div>

          </div>


          <!-- Size -->

          <div class="product-option-group">

            <div class="product-option-heading">

              <strong>Choose size</strong>

              <button
                class="size-guide-open"
                id="sizeGuideOpen"
                type="button"
              >
                📏 Size guide
              </button>

            </div>

            <div
              class="product-size-options"
              id="productSizeOptions"
            ></div>

          </div>


          <!-- Stock -->

          <div class="product-stock-panel">

            <div class="product-stock-message">
              <span id="variantStockDot"></span>

              <span id="variantStockText">
                <%= firstVariant.stock %> available
              </span>
            </div>

            <div class="product-stock-track">
              <span
                id="productStockProgress"
                style="width:
                  <%= Math.min(
                    Math.max(
                      Number(firstVariant.stock || 0) * 10,
                      5
                    ),
                    100
                  ) %>%"
              ></span>
            </div>

            <small id="productStockNotice">
              <% if (firstVariant.stock > 10) { %>
                Available and ready to order
              <% } else if (firstVariant.stock > 0) { %>
                Selling quickly — order soon
              <% } else { %>
                This color is currently unavailable
              <% } %>
            </small>

          </div>


          <!-- Quantity + Add to cart -->

          <div class="product-buy-row">

            <div class="quantity-control">

              <button
                type="button"
                id="decreaseQuantity"
                aria-label="Decrease quantity"
              >
                −
              </button>

              <input
                type="number"
                name="quantity"
                id="productQuantity"
                value="1"
                min="1"
                max="<%= Math.max(firstVariant.stock, 1) %>"
                inputmode="numeric"
              >

              <button
                type="button"
                id="increaseQuantity"
                aria-label="Increase quantity"
              >
                +
              </button>

            </div>

            <button
              class="btn gold-btn product-add-button"
              id="productAddButton"
              type="submit"
              <%= firstVariant.stock < 1
                ? 'disabled'
                : ''
              %>
            >
              <%= firstVariant.stock < 1
                ? 'Out of stock'
                : 'Add to cart'
              %>
            </button>

          </div>


          <!-- Buy now -->

          <button
            class="product-buy-now-button"
            id="productBuyNowButton"
            type="submit"
            name="redirectTo"
            value="/checkout"
            <%= firstVariant.stock < 1
              ? 'disabled'
              : ''
            %>
          >
            Buy now
          </button>

        </form>


        <!-- Delivery information -->

        <div class="product-delivery-panel">

          <div class="product-delivery-item">
            <span>🚚</span>

            <div>
              <strong>Nationwide delivery</strong>
              <small>
                Dhaka 1–2 days, outside Dhaka 2–4 days
              </small>
            </div>
          </div>

          <div class="product-delivery-item">
            <span>৳</span>

            <div>
              <strong>Free delivery over ৳3,000</strong>
              <small>
                Standard delivery charge applies below ৳3,000
              </small>
            </div>
          </div>

          <div class="product-delivery-item">
            <span>↻</span>

            <div>
              <strong>Easy exchange support</strong>
              <small>
                Contact support if size or product has an issue
              </small>
            </div>
          </div>

          <div class="product-delivery-item">
            <span>✓</span>

            <div>
              <strong>Secure payment</strong>
              <small>
                COD, bKash and Nagad available
              </small>
            </div>
          </div>

        </div>


        <!-- Trust badges -->

        <div class="product-trust-grid">

          <span>Premium quality</span>
          <span>Secure checkout</span>
          <span>Order tracking</span>
          <span>Customer support</span>

        </div>


        <!-- Share -->

        <div class="product-share-section">

          <strong>Share this product</strong>

          <div class="product-share-buttons">

            <a
              id="shareFacebook"
              href="#"
              target="_blank"
              rel="noopener noreferrer"
            >
              <i class="bi bi-facebook" aria-hidden="true"></i>
              <span>Facebook</span>
            </a>

            <a
              id="shareWhatsApp"
              href="#"
              target="_blank"
              rel="noopener noreferrer"
            >
              <i class="bi bi-whatsapp" aria-hidden="true"></i>
              <span>WhatsApp</span>
            </a>

            <button
              id="copyProductLink"
              type="button"
            >
              <i class="bi bi-link-45deg" aria-hidden="true"></i>
              <span>Copy link</span>
            </button>

          </div>

          <small id="copyLinkMessage"></small>

        </div>


        <!-- Accordion -->

        <div class="product-accordion">

          <article class="product-accordion-item active">

            <button type="button">
              <span>Product details</span>
              <strong>−</strong>
            </button>

            <div class="product-accordion-content">
              <p><%= product.description %></p>
            </div>

          </article>


          <article class="product-accordion-item">

            <button type="button">
              <span>Material and care</span>
              <strong>＋</strong>
            </button>

            <div class="product-accordion-content">

              <p>
                Material:
                <%= product.material || 'Please check the product label.' %>
              </p>

              <p>
                Wash gently using mild detergent.
                Avoid strong bleach and excessive heat.
              </p>

            </div>

          </article>


          <article class="product-accordion-item">

            <button type="button">
              <span>Delivery information</span>
              <strong>＋</strong>
            </button>

            <div class="product-accordion-content">

              <p>
                Orders are delivered through supported
                courier services across Bangladesh.
              </p>

              <p>
                Delivery time may vary depending on your
                location and courier conditions.
              </p>

            </div>

          </article>


          <article class="product-accordion-item">

            <button type="button">
              <span>Exchange and support</span>
              <strong>＋</strong>
            </button>

            <div class="product-accordion-content">

              <p>
                Please inspect the product after receiving it.
                Contact support promptly if there is a size,
                manufacturing or delivery issue.
              </p>

            </div>

          </article>

        </div>

      </div>

    </div>

<section class="product-review-section">

  <div class="review-section-header">
    <span class="section-kicker">CUSTOMER FEEDBACK</span>
    <h2>Customer Reviews</h2>
  </div>

  <% if (currentUser) { %>

    <form
      class="review-form"
      action="/product/<%= product._id %>/reviews"
      method="post"
    >

      <div class="field">
        <label for="rating">Your Rating</label>

        <select
          id="rating"
          name="rating"
          required
        >
          <option value="">Select rating</option>
          <option value="5">★★★★★ — Excellent</option>
          <option value="4">★★★★☆ — Very Good</option>
          <option value="3">★★★☆☆ — Good</option>
          <option value="2">★★☆☆☆ — Fair</option>
          <option value="1">★☆☆☆☆ — Poor</option>
        </select>
      </div>

      <div class="field">
        <label for="comment">Your Review</label>

        <textarea
          id="comment"
          name="comment"
          rows="5"
          maxlength="1000"
          placeholder="Write your experience with this product..."
          required
        ></textarea>
      </div>

      <button
        class="btn gold-btn"
        type="submit"
      >
        <i class="bi bi-send"></i>
        Submit Review
      </button>

    </form>

  <% } else { %>

    <div class="review-login-box">
      <p>
        Please login to rate and review this product.
      </p>

      <a
        class="btn gold-btn"
        href="/auth?tab=login"
      >
        <i class="bi bi-person"></i>
        Login to Review
      </a>
    </div>

  <% } %>


  <div class="customer-review-list">

    <% if (reviews && reviews.length) { %>

      <% reviews.forEach(review => { %>

        <article class="customer-review-card">

          <div class="customer-review-top">

            <div>
              <strong><%= review.name %></strong>

              <div class="review-stars">
                <% for (let star = 1; star <= 5; star++) { %>
                  <span class="<%= star <= review.rating ? 'active' : '' %>">
                    ★
                  </span>
                <% } %>
              </div>
            </div>

            <% if (review.createdAt) { %>
              <time>
                <%= new Date(review.createdAt).toLocaleDateString('en-BD') %>
              </time>
            <% } %>

          </div>

          <p><%= review.comment %></p>

        </article>

      <% }) %>

    <% } else { %>

      <div class="no-reviews-box">
        <i class="bi bi-chat-square-text"></i>
        <p>No reviews yet. Be the first to review this product.</p>
      </div>

    <% } %>

  </div>

</section>
    <!-- Related products: rendered only when route provides them -->

    <% if (
      typeof relatedProducts !== 'undefined' &&
      Array.isArray(relatedProducts) &&
      relatedProducts.length
    ) { %>

      <section class="related-products-section">

        <div class="section-head">

          <div>
            <span class="section-kicker">
              YOU MAY ALSO LIKE
            </span>

            <h2>Related products</h2>
          </div>

          <a
            class="view-all-link"
            href="/shop?category=<%= encodeURIComponent(product.category) %>"
          >
            View collection →
          </a>

        </div>

        <div class="shop-product-grid">

          <% relatedProducts.forEach(p => { %>

            <%- include(
              'partials/product-card',
              { p }
            ) %>

          <% }) %>

        </div>

      </section>

    <% } %>


    <!-- Recently viewed -->

    <section
      class="recently-viewed-section"
      id="recentlyViewedSection"
      hidden
    >

      <div class="section-head">

        <div>
          <span class="section-kicker">
            YOUR HISTORY
          </span>

          <h2>Recently viewed</h2>
        </div>

      </div>

      <div
        class="recently-viewed-grid"
        id="recentlyViewedGrid"
      ></div>

    </section>

  </div>

</section>


<!-- Variant data -->

<script
  type="application/json"
  id="productVariantData"
><%- variantJson %></script>


<!-- Current product data -->

<script
  type="application/json"
  id="currentProductData"
><%- JSON.stringify({
  productId: product._id.toString(),
  name: product.name,
  slug: product.slug,
  image:
    firstVariant.images?.[0]?.url ||
    fallbackImage,
  price: Number(product.price)
}).replace(/</g, '\\u003c') %></script>


<!-- Full-screen image modal -->

<div
  class="product-image-modal"
  id="productImageModal"
  aria-hidden="true"
>

  <button
    class="product-modal-close"
    id="productModalClose"
    type="button"
    aria-label="Close image"
  >
    ×
  </button>

  <button
    class="product-modal-arrow previous"
    id="productModalPrevious"
    type="button"
    aria-label="Previous image"
  >
    ‹
  </button>

  <img
    id="productModalImage"
    src="<%= firstVariant.images?.[0]?.url || fallbackImage %>"
    alt="<%= product.name %> enlarged image"
  >

  <button
    class="product-modal-arrow next"
    id="productModalNext"
    type="button"
    aria-label="Next image"
  >
    ›
  </button>

</div>


<!-- Size guide modal -->

<div
  class="size-guide-modal"
  id="sizeGuideModal"
  aria-hidden="true"
>

  <div class="size-guide-dialog">

    <button
      class="size-guide-close"
      id="sizeGuideClose"
      type="button"
      aria-label="Close size guide"
    >
      ×
    </button>

    <span class="section-kicker">
      TTT OUTFIT SIZE GUIDE
    </span>

    <h2>Choose your best fit</h2>

    <div class="size-guide-table-wrap">

      <table class="size-guide-table">

        <thead>
          <tr>
            <th>Size</th>
            <th>Chest</th>
            <th>Length</th>
            <th>Recommended fit</th>
          </tr>
        </thead>

        <tbody>
          <tr>
            <td>S</td>
            <td>36–38″</td>
            <td>26–27″</td>
            <td>Slim</td>
          </tr>

          <tr>
            <td>M</td>
            <td>38–40″</td>
            <td>27–28″</td>
            <td>Regular</td>
          </tr>

          <tr>
            <td>L</td>
            <td>40–42″</td>
            <td>28–29″</td>
            <td>Regular</td>
          </tr>

          <tr>
            <td>XL</td>
            <td>42–44″</td>
            <td>29–30″</td>
            <td>Relaxed</td>
          </tr>

          <tr>
            <td>XXL</td>
            <td>44–46″</td>
            <td>30–31″</td>
            <td>Relaxed</td>
          </tr>
        </tbody>

      </table>

    </div>

    <p>
      Measurements are general guidance. Actual size may
      vary slightly depending on product style and fabric.
    </p>

  </div>

</div>


<script>
  document.addEventListener('DOMContentLoaded', () => {
    const variants = JSON.parse(
      document.getElementById(
        'productVariantData'
      ).textContent
    );

    const currentProduct = JSON.parse(
      document.getElementById(
        'currentProductData'
      ).textContent
    );

    const mainImage =
      document.getElementById('productMainImage');

    const thumbnails =
      document.getElementById(
        'productThumbnailList'
      );

    const colorInput =
      document.getElementById('selectedColor');

    const colorLabel =
      document.getElementById(
        'selectedColorLabel'
      );

    const sizeInput =
      document.getElementById('selectedSize');

    const sizeOptions =
      document.getElementById(
        'productSizeOptions'
      );

    const stockText =
      document.getElementById(
        'variantStockText'
      );

    const stockDot =
      document.getElementById(
        'variantStockDot'
      );

    const stockProgress =
      document.getElementById(
        'productStockProgress'
      );

    const stockNotice =
      document.getElementById(
        'productStockNotice'
      );

    const quantityInput =
      document.getElementById(
        'productQuantity'
      );

    const addButton =
      document.getElementById(
        'productAddButton'
      );

    const buyNowButton =
      document.getElementById(
        'productBuyNowButton'
      );

    const colorButtons =
      document.querySelectorAll(
        '.product-color-option'
      );

    const productModal =
      document.getElementById(
        'productImageModal'
      );

    const productModalImage =
      document.getElementById(
        'productModalImage'
      );

    let currentVariant =
      variants[0];

    let currentImageIndex = 0;


    function getVariantImages(variant) {
      return variant.images?.length
        ? variant.images
        : [{
            url:
              'https://via.placeholder.com/800x1000?text=TTT+Outfit'
          }];
    }


    function setMainImage(
      url,
      clickedButton = null,
      imageIndex = 0
    ) {
      if (!url || !mainImage) return;

      currentImageIndex =
        imageIndex;

      mainImage.classList.add('changing');

      setTimeout(() => {
        mainImage.src = url;
        mainImage.classList.remove('changing');
      }, 120);

      if (productModalImage) {
        productModalImage.src = url;
      }

      thumbnails
        ?.querySelectorAll('.product-thumbnail')
        .forEach(button => {
          button.classList.toggle(
            'active',
            button === clickedButton
          );
        });
    }


    function renderThumbnails(variant) {
      if (!thumbnails) return;

      thumbnails.innerHTML = '';

      const images =
        getVariantImages(variant);

      images.forEach((image, index) => {
        const button =
          document.createElement('button');

        button.type = 'button';

        button.className =
          `product-thumbnail ${
            index === 0 ? 'active' : ''
          }`;

        button.dataset.image =
          image.url;

        button.dataset.imageIndex =
          String(index);

        button.setAttribute(
          'aria-label',
          `View image ${index + 1}`
        );

        const imageElement =
          document.createElement('img');

        imageElement.src =
          image.url;

        imageElement.alt =
          `${currentProduct.name} image ${index + 1}`;

        button.appendChild(imageElement);

        button.addEventListener('click', () => {
          setMainImage(
            image.url,
            button,
            index
          );
        });

        thumbnails.appendChild(button);
      });

      setMainImage(
        images[0].url,
        thumbnails.firstElementChild,
        0
      );
    }


    function renderSizes(variant) {
      if (!sizeOptions || !sizeInput) return;

      sizeOptions.innerHTML = '';

      const sizes =
        variant.sizes?.length
          ? variant.sizes
          : ['One Size'];

      sizes.forEach((size, index) => {
        const button =
          document.createElement('button');

        button.type = 'button';
        button.textContent = size;

        button.className =
          `product-size-option ${
            index === 0 ? 'active' : ''
          }`;

        button.addEventListener('click', () => {
          sizeOptions
            .querySelectorAll(
              '.product-size-option'
            )
            .forEach(item => {
              item.classList.remove('active');
            });

          button.classList.add('active');
          sizeInput.value = size;
        });

        sizeOptions.appendChild(button);
      });

      sizeInput.value = sizes[0];
    }


    function updateStock(variant) {
      const stock =
        Number(variant.stock || 0);

      quantityInput.max =
        String(Math.max(stock, 1));

      quantityInput.value = '1';

      const progress =
        stock > 0
          ? Math.min(
              Math.max(stock * 10, 8),
              100
            )
          : 0;

      stockProgress.style.width =
        `${progress}%`;

      if (stock > 0) {
        stockText.textContent =
          `${stock} available`;

        stockDot.classList.remove(
          'out-of-stock'
        );

        addButton.disabled = false;
        buyNowButton.disabled = false;

        addButton.textContent =
          'Add to cart';

        stockNotice.textContent =
          stock <= 5
            ? 'Selling quickly — order soon'
            : 'Available and ready to order';
      } else {
        stockText.textContent =
          'Out of stock';

        stockDot.classList.add(
          'out-of-stock'
        );

        addButton.disabled = true;
        buyNowButton.disabled = true;

        addButton.textContent =
          'Out of stock';

        stockNotice.textContent =
          'This color is currently unavailable';
      }
    }


    function selectVariant(index) {
      const variant =
        variants[index];

      if (!variant) return;

      currentVariant =
        variant;

      colorInput.value =
        variant.color;

      colorLabel.textContent =
        variant.color;

      renderThumbnails(variant);
      renderSizes(variant);
      updateStock(variant);

      colorButtons.forEach(
        (button, itemIndex) => {
          button.classList.toggle(
            'active',
            itemIndex === index
          );
        }
      );
    }


    colorButtons.forEach(button => {
      button.addEventListener('click', () => {
        selectVariant(
          Number(
            button.dataset.variantIndex
          )
        );
      });
    });


    document
      .getElementById('decreaseQuantity')
      ?.addEventListener('click', () => {
        quantityInput.value = String(
          Math.max(
            1,
            Number(quantityInput.value) - 1
          )
        );
      });


    document
      .getElementById('increaseQuantity')
      ?.addEventListener('click', () => {
        const maximum =
          Number(currentVariant.stock || 1);

        quantityInput.value = String(
          Math.min(
            maximum,
            Number(quantityInput.value) + 1
          )
        );
      });


    quantityInput?.addEventListener(
      'change',
      () => {
        const maximum =
          Number(currentVariant.stock || 1);

        quantityInput.value = String(
          Math.max(
            1,
            Math.min(
              Number(quantityInput.value) || 1,
              maximum
            )
          )
        );
      }
    );


    /* Full-screen image modal */

    function openImageModal() {
      if (
        !productModal ||
        !productModalImage
      ) {
        return;
      }

      productModalImage.src =
        mainImage.src;

      productModal.classList.add(
        'active'
      );

      productModal.setAttribute(
        'aria-hidden',
        'false'
      );

      document.body.style.overflow =
        'hidden';
    }


    function closeImageModal() {
      if (!productModal) return;

      productModal.classList.remove(
        'active'
      );

      productModal.setAttribute(
        'aria-hidden',
        'true'
      );

      document.body.style.overflow =
        '';
    }


    function changeModalImage(direction) {
      const images =
        getVariantImages(currentVariant);

      currentImageIndex =
        (
          currentImageIndex +
          direction +
          images.length
        ) % images.length;

      const selectedImage =
        images[currentImageIndex];

      productModalImage.src =
        selectedImage.url;

      mainImage.src =
        selectedImage.url;

      const matchingButton =
        thumbnails?.querySelectorAll(
          '.product-thumbnail'
        )[currentImageIndex];

      thumbnails
        ?.querySelectorAll(
          '.product-thumbnail'
        )
        .forEach(button => {
          button.classList.toggle(
            'active',
            button === matchingButton
          );
        });
    }


    document
      .getElementById('productZoomButton')
      ?.addEventListener(
        'click',
        openImageModal
      );

    mainImage?.addEventListener(
      'click',
      openImageModal
    );

    document
      .getElementById('productModalClose')
      ?.addEventListener(
        'click',
        closeImageModal
      );

    document
      .getElementById(
        'productModalPrevious'
      )
      ?.addEventListener(
        'click',
        () => changeModalImage(-1)
      );

    document
      .getElementById(
        'productModalNext'
      )
      ?.addEventListener(
        'click',
        () => changeModalImage(1)
      );

    productModal?.addEventListener(
      'click',
      event => {
        if (event.target === productModal) {
          closeImageModal();
        }
      }
    );


    /* Size guide */

    const sizeGuideModal =
      document.getElementById(
        'sizeGuideModal'
      );

    function openSizeGuide() {
      sizeGuideModal?.classList.add(
        'active'
      );

      sizeGuideModal?.setAttribute(
        'aria-hidden',
        'false'
      );

      document.body.style.overflow =
        'hidden';
    }

    function closeSizeGuide() {
      sizeGuideModal?.classList.remove(
        'active'
      );

      sizeGuideModal?.setAttribute(
        'aria-hidden',
        'true'
      );

      document.body.style.overflow =
        '';
    }

    document
      .getElementById('sizeGuideOpen')
      ?.addEventListener(
        'click',
        openSizeGuide
      );

    document
      .getElementById('sizeGuideClose')
      ?.addEventListener(
        'click',
        closeSizeGuide
      );

    sizeGuideModal?.addEventListener(
      'click',
      event => {
        if (
          event.target === sizeGuideModal
        ) {
          closeSizeGuide();
        }
      }
    );


    /* Accordion */

    document
      .querySelectorAll(
        '.product-accordion-item > button'
      )
      .forEach(button => {
        button.addEventListener(
          'click',
          () => {
            const item =
              button.closest(
                '.product-accordion-item'
              );

            const isOpen =
              item.classList.contains(
                'active'
              );

            item.classList.toggle(
              'active',
              !isOpen
            );

            button.querySelector(
              'strong'
            ).textContent =
              isOpen ? '＋' : '−';
          }
        );
      });


    /* Share */

    const productUrl =
      window.location.href;

    const productShareText =
      `${currentProduct.name} — TTT Outfit`;

    const facebookShare =
      document.getElementById(
        'shareFacebook'
      );

    const whatsappShare =
      document.getElementById(
        'shareWhatsApp'
      );

    if (facebookShare) {
      facebookShare.href =
        `https://www.facebook.com/sharer/sharer.php?u=${
          encodeURIComponent(productUrl)
        }`;
    }

    if (whatsappShare) {
      whatsappShare.href =
        `https://wa.me/?text=${
          encodeURIComponent(
            `${productShareText} ${productUrl}`
          )
        }`;
    }

    document
      .getElementById('copyProductLink')
      ?.addEventListener(
        'click',
        async () => {
          const message =
            document.getElementById(
              'copyLinkMessage'
            );

          try {
            if (
              navigator.clipboard &&
              window.isSecureContext
            ) {
              await navigator.clipboard.writeText(
                productUrl
              );
            } else {
              const temporaryInput =
                document.createElement('textarea');

              temporaryInput.value = productUrl;
              temporaryInput.setAttribute(
                'readonly',
                ''
              );

              temporaryInput.style.position =
                'fixed';

              temporaryInput.style.opacity =
                '0';

              document.body.appendChild(
                temporaryInput
              );

              temporaryInput.select();

              const copied =
                document.execCommand('copy');

              temporaryInput.remove();

              if (!copied) {
                throw new Error(
                  'Copy command failed.'
                );
              }
            }

            if (message) {
              message.textContent =
                'Product link copied.';
            }
          } catch {
            if (message) {
              message.textContent =
                'Copy the link from your browser.';
            }
          }

          setTimeout(() => {
            message.textContent = '';
          }, 2500);
        }
      );





    /* Recently viewed */

    function saveRecentlyViewed() {
      let recentlyViewed = [];

      try {
        recentlyViewed = JSON.parse(
          localStorage.getItem(
            'tttRecentlyViewed'
          ) || '[]'
        );
      } catch {
        recentlyViewed = [];
      }

      recentlyViewed =
        recentlyViewed.filter(
          item =>
            item.productId !==
            currentProduct.productId
        );

      recentlyViewed.unshift(
        currentProduct
      );

      localStorage.setItem(
        'tttRecentlyViewed',
        JSON.stringify(
          recentlyViewed.slice(0, 6)
        )
      );
    }


    function renderRecentlyViewed() {
      const section =
        document.getElementById(
          'recentlyViewedSection'
        );

      const grid =
        document.getElementById(
          'recentlyViewedGrid'
        );

      if (!section || !grid) return;

      let items = [];

      try {
        items = JSON.parse(
          localStorage.getItem(
            'tttRecentlyViewed'
          ) || '[]'
        );
      } catch {
        items = [];
      }

      items =
        items.filter(
          item =>
            item.productId !==
            currentProduct.productId
        );

      if (!items.length) return;

      section.hidden = false;
      grid.innerHTML = '';

      items.forEach(item => {
        const card =
          document.createElement('a');

        card.className =
          'recent-product-card';

        card.href =
          `/product/${encodeURIComponent(
            item.slug
          )}`;

        card.innerHTML = `
          <img
            src="${item.image}"
            alt=""
            loading="lazy"
          >

          <div>
            <strong>${item.name}</strong>
            <span>
              ৳${Number(
                item.price
              ).toLocaleString('en-BD')}
            </span>
          </div>
        `;

        grid.appendChild(card);
      });
    }


    document.addEventListener(
      'keydown',
      event => {
        if (event.key === 'Escape') {
          closeImageModal();
          closeSizeGuide();
        }
      }
    );


    renderRecentlyViewed();
    saveRecentlyViewed();
    selectVariant(0);
  });
</script>

<%- include('partials/footer') %>
