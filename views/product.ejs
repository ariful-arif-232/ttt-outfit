<%- include('partials/header') %><section class="section"><div class="container product-page"><div><img class="main-image" src="<%= product.images?.[0]?.url || 'https://via.placeholder.com/800x1000' %>" alt="<%= product.name %>"></div><div><span class="badge"><%= product.category %></span><h1><%= product.name %></h1><p><span class="price">৳<%= money(product.price) %></span><% if(product.compareAtPrice>product.price){ %><span class="old-price">৳<%= money(product.compareAtPrice) %></span><% } %></p><p><%= product.description %></p><p class="small">SKU: <%= product.sku %> · Material: <%= product.material || 'Not specified' %> · Stock: <%= product.stock %></p><form method="post" action="/cart/add"><input type="hidden" name="productId" value="<%= product._id %>"><div class="field"><label>Size</label><select name="size"><% (product.sizes.length?product.sizes:['One Size']).forEach(s=>{ %><option><%= s %></option><% }) %></select></div><div class="field"><label>Color</label><select name="color"><% (product.colors.length?product.colors:['Default']).forEach(c=>{ %><option><%= c %></option><% }) %></select></div><div class="field"><label>Quantity</label><input type="number" name="quantity" value="1" min="1" max="<%= product.stock %>"></div><button class="btn" <%= product.stock<1?'disabled':'' %>><%= product.stock<1?'Out of stock':'Add to cart' %></button></form></div></div></section><%- include('partials/footer') %>
