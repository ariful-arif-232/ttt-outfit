<%- include('../partials/header') %><div class="container admin-layout"><%- include('../partials/admin-nav') %><section class="panel"><h1><%= product?'Edit product':'Add product' %></h1><form method="post" enctype="multipart/form-data" action="<%= product?'/admin/products/'+product._id:'/admin/products' %>"><div class="field"><label>Name *</label><input name="name" value="<%= product?.name||'' %>" required></div><div class="field"><label>Slug</label><input name="slug" value="<%= product?.slug||'' %>"></div><div class="field"><label>SKU *</label><input name="sku" value="<%= product?.sku||'' %>" required></div><div class="field"><label>Description *</label><textarea name="description" required><%= product?.description||'' %></textarea></div><div class="field"><label>Category *</label><input name="category" value="<%= product?.category||'' %>" required></div><div class="field"><label>Gender</label><select name="gender"><% ['Unisex','Men','Women','Kids'].forEach(g=>{ %><option <%= product?.gender===g?'selected':'' %>><%= g %></option><% }) %></select></div><div class="field"><label>Material</label><input name="material" value="<%= product?.material||'' %>"></div><div class="two-col"><div class="field"><label>Price *</label><input type="number" name="price" value="<%= product?.price||'' %>" required></div><div class="field"><label>Old price</label><input type="number" name="compareAtPrice" value="<%= product?.compareAtPrice||0 %>"></div></div><div class="field"><label>Stock *</label><input type="number" name="stock" value="<%= product?.stock||0 %>" required></div><div class="field"><label>Sizes (comma-separated)</label><input name="sizes" value="<%= product?.sizes?.join(', ')||'' %>"></div><div class="field"><label>Colors (comma-separated)</label><input name="colors" value="<%= product?.colors?.join(', ')||'' %>"></div><div class="field"><label>Upload image <span class="small"><%= cloudinaryReady?'Cloudinary connected':'Cloudinary not configured; use image URL below' %></span></label><input type="file" name="image" accept="image/*"></div><div class="field"><label>Image URL fallback</label><input name="imageUrl" value="<%= product?.images?.[0]?.url||'' %>"></div><label><input type="checkbox" name="featured" <%= product?.featured?'checked':'' %>> Featured</label><br><label><input type="checkbox" name="active" <%= product===null||product?.active?'checked':'' %>> Active</label><br><br><button class="btn">Save product</button></form></section></div><%- include('../partials/footer') %>
