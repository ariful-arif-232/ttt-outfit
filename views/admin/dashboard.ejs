<%- include('../partials/header') %><div class="container admin-layout"><%- include('../partials/admin-nav') %><section><h1>Dashboard</h1><div class="stat-grid"><div class="stat">Delivered sales<strong>৳<%= money(stats.sales) %></strong></div><div class="stat">Products<strong><%= stats.productCount %></strong></div><div class="stat">Customers<strong><%= stats.customerCount %></strong></div><div class="stat">Pending orders<strong><%= stats.pendingCount %></strong></div></div><h2>Recent orders</h2><table><tr><th>Order</th><th>Customer</th><th>Total</th><th>Status</th></tr><% recentOrders.forEach(o=>{ %><tr><td><a href="/orders/<%= o._id %>"><%= o.orderNumber %></a></td><td><%= o.customer?.name || o.customerSnapshot.name %></td><td>৳<%= money(o.total) %></td><td><%= o.status %></td></tr><% }) %></table><h2>Low stock</h2><table><tr><th>Product</th><th>SKU</th><th>Stock</th></tr><% lowStock.forEach(p=>{ %><tr><td><%= p.name %></td><td><%= p.sku %></td><td><%= p.stock %></td></tr><% }) %></table></section></div><%- include('../partials/footer') %>
