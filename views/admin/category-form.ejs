<%- include('../partials/header') %>

<div class="container admin-layout">
  <%- include('../partials/admin-nav') %>

  <section class="panel">

    <div class="admin-form-heading">
      <div>
        <span class="section-kicker">
          HOMEPAGE MANAGEMENT
        </span>

        <h1>
          <%= category ? 'Edit category' : 'Add category' %>
        </h1>

        <p class="small">
          One category record can control menu placement,
          showcase cards and product rails.
        </p>
      </div>
    </div>

    <form
      method="post"
      enctype="multipart/form-data"
      action="<%= category
        ? '/admin/categories/' + category._id
        : '/admin/categories'
      %>"
    >

      <div class="two-col">

        <div class="field">
          <label for="categoryName">Name *</label>

          <input
            id="categoryName"
            name="name"
            value="<%= category?.name || '' %>"
            placeholder="Example: Polo Shirt"
            required
          >
        </div>

        <div class="field">
          <label for="categorySlug">Slug</label>

          <input
            id="categorySlug"
            name="slug"
            value="<%= category?.slug || '' %>"
            placeholder="Generated from name"
          >

          <p class="small">
            Example: polo-shirt
          </p>
        </div>

      </div>

      <div class="two-col">

        <div class="field">
          <label for="categoryGroup">Parent group *</label>

          <input
            id="categoryGroup"
            name="group"
            list="categoryGroupSuggestions"
            value="<%= category?.group || '' %>"
            placeholder="Select or type a new parent group"
            autocomplete="off"
            required
          >

          <datalist id="categoryGroupSuggestions">
            <% (groups || []).forEach(group => { %>
              <option value="<%= group %>"></option>
            <% }) %>
          </datalist>

          <p class="small">
            Select an existing group or type a completely new group,
            such as Accessories, Sports Wear or Kids Wear.
          </p>
        </div>

        <div class="field">
          <label for="displayOrder">Display order</label>

          <input
            id="displayOrder"
            type="number"
            name="displayOrder"
            value="<%= category?.displayOrder ?? 0 %>"
            step="1"
            min="0"
          >
        </div>

      </div>

      <div class="two-col">

        <div class="field">
          <label for="buttonText">Button text</label>

          <input
            id="buttonText"
            name="buttonText"
            value="<%= category?.buttonText || 'Shop Now' %>"
          >
        </div>

        <div class="field">
          <label for="offerText">Offer text</label>

          <input
            id="offerText"
            name="offerText"
            value="<%= category?.offerText || 'GET 20% OFF' %>"
          >
        </div>

      </div>

      <div class="two-col">

        <div class="field">
          <label for="categoryImageUrl">Image URL</label>

          <input
            id="categoryImageUrl"
            type="url"
            name="imageUrl"
            value="<%= category?.image?.url || '' %>"
            placeholder="https://..."
          >
        </div>

        <div class="field">
          <label for="categoryImageFile">Upload image</label>

          <input
            id="categoryImageFile"
            type="file"
            name="imageFile"
            accept="image/*"
            <%= cloudinaryReady ? '' : 'disabled' %>
          >

          <p class="small">
            <%= cloudinaryReady
              ? 'Uploaded image takes priority over the image URL.'
              : 'Cloudinary is not configured. Use an image URL.'
            %>
          </p>
        </div>

      </div>

      <% if (category?.image?.url) { %>
        <div class="admin-image-preview">
          <img
            src="<%= category.image.url %>"
            alt="<%= category.image.alt || category.name %>"
          >
        </div>
      <% } %>

      <fieldset class="admin-check-grid">
        <legend>Visibility</legend>

        <label>
          <input
            type="checkbox"
            name="showInMenu"
            <%= category
              ? (category.showInMenu ? 'checked' : '')
              : 'checked'
            %>
          >
          Show in drawer menu
        </label>

        <label>
          <input
            type="checkbox"
            name="showInShowcase"
            <%= category
              ? (category.showInShowcase ? 'checked' : '')
              : 'checked'
            %>
          >
          Show in Ready to Wear
        </label>

        <label>
          <input
            type="checkbox"
            name="showOnHomepage"
            <%= category
              ? (category.showOnHomepage ? 'checked' : '')
              : 'checked'
            %>
          >
          Show product rail
        </label>

        <label>
          <input
            type="checkbox"
            name="active"
            <%= category
              ? (category.active ? 'checked' : '')
              : 'checked'
            %>
          >
          Active
        </label>
      </fieldset>

      <div class="form-actions">
        <button class="btn gold-btn" type="submit">
          <%= category ? 'Save changes' : 'Create category' %>
        </button>

        <a class="btn ghost-btn" href="/admin/categories">
          Cancel
        </a>
      </div>

    </form>

  </section>
</div>

<%- include('../partials/footer') %>
