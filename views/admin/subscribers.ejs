<%- include('../partials/header') %>
<div class="container admin-layout"><%- include('../partials/admin-nav') %><section class="admin-products-page">
<div class="section-head admin-products-heading"><div><span class="section-kicker">COMMUNITY</span><h1>Newsletter Subscribers</h1><p class="small">Review subscriber status and subscription source.</p></div></div>
<% const safeSubscribers = Array.isArray(subscribers) ? subscribers : []; %>
<div class="admin-product-summary-grid"><article><span>Total</span><strong><%= safeSubscribers.length %></strong></article><article><span>Active</span><strong><%= safeSubscribers.filter(s => s.status === 'active').length %></strong></article><article><span>Unsubscribed</span><strong><%= safeSubscribers.filter(s => s.status !== 'active').length %></strong></article><article><span>Homepage source</span><strong><%= safeSubscribers.filter(s => s.source === 'homepage').length %></strong></article></div>
<% if (safeSubscribers.length) { %><div class="admin-table-wrap"><table class="admin-products-table"><thead><tr><th>Email</th><th>Source</th><th>Subscribed</th><th>Status</th><th>Action</th></tr></thead><tbody><% safeSubscribers.forEach(subscriber => { %><tr><td><strong><%= subscriber.email %></strong></td><td><%= subscriber.source || 'homepage' %></td><td><%= subscriber.subscribedAt ? new Date(subscriber.subscribedAt).toLocaleString('en-BD') : '—' %></td><td><span class="status-pill <%= subscriber.status === 'active' ? 'active' : 'inactive' %>"><%= subscriber.status %></span></td><td><div class="table-actions"><form method="post" action="/admin/subscribers/<%= subscriber._id %>/toggle"><button class="btn small-btn" type="submit"><%= subscriber.status === 'active' ? 'Unsubscribe' : 'Reactivate' %></button></form><form method="post" action="/admin/subscribers/<%= subscriber._id %>/delete" onsubmit="return confirm('Permanently delete this subscriber?')"><button class="btn ghost-btn small-btn" type="submit">Delete</button></form></div></td></tr><% }) %></tbody></table></div><% } else { %><div class="empty-state"><h2>No subscribers yet</h2><p>Newsletter sign-ups will appear here.</p></div><% } %>
</section></div><%- include('../partials/footer') %>
