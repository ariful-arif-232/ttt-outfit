<%- include('../partials/header') %><div class="container admin-layout"><%- include('../partials/admin-nav') %><section><div class="section-head"><h1>Products</h1><a class="btn" href="/admin/products/new">Add product</a></div><table><tr><th>Product</th><th>Price</th><th>Stock</th><th>Status</th><th>Action</th></tr><% products.forEach(p=>{ %><tr><td><strong><%= p.name %></strong><br><span class="small"><%= p.sku %></span></td><td>৳<%= money(p.price) %></td><td><%= p.stock %></td><td><%= p.active?'Active':'Hidden' %></td><td class="actions"><a href="/admin/products/<%= p._id %>/edit">Edit</a><form method="post" action="/admin/products/<%= p._id %>/delete"><button>Hide</button></form></td></tr><% }) %></table></section></div><%- include('../partials/footer') %>
