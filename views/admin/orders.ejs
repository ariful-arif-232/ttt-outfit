<%- include('../partials/header') %><div class="container admin-layout"><%- include('../partials/admin-nav') %><section><h1>Orders</h1><form class="filters"><select name="status"><option value="">All statuses</option><% ['Pending','Confirmed','Processing','Shipped','Delivered','Cancelled','Returned'].forEach(s=>{ %><option <%= selectedStatus===s?'selected':'' %>><%= s %></option><% }) %></select><button class="btn">Filter</button></form><% orders.forEach(o=>{ %><div class="order-card"><strong><a href="/orders/<%= o._id %>"><%= o.orderNumber %></a></strong><span style="float:right">৳<%= money(o.total) %></span><p><%= o.customer?.name || o.customerSnapshot.name %> · <%= o.customerSnapshot.phone %></p><form method="post" action="/admin/orders/<%= o._id %>/update" class="filters"><select name="status"><% ['Pending','Confirmed','Processing','Shipped','Delivered','Cancelled','Returned'].forEach(s=>{ %><option <%= o.status===s?'selected':'' %>><%= s %></option><% }) %></select><select name="paymentStatus"><% ['Pending','Paid','Failed','Refunded'].forEach(s=>{ %><option <%= o.paymentStatus===s?'selected':'' %>><%= s %></option><% }) %></select><input name="note" placeholder="Optional note"><button class="btn">Update</button></form></div><% }) %></section></div><%- include('../partials/footer') %>
