<%- include('../partials/header') %>
<div class="container admin-layout"><%- include('../partials/admin-nav') %><section class="admin-products-page">
<div class="section-head admin-products-heading"><div><span class="section-kicker">HOMEPAGE MANAGEMENT</span><h1>Hero Sliders</h1><p class="small">Manage desktop/mobile images, copy, links, position and order.</p></div><a class="btn gold-btn" href="/admin/sliders/new"><i class="bi bi-plus-lg"></i> Add slide</a></div>
<% const safeSliders = Array.isArray(sliders) ? sliders : []; %>
<div class="admin-product-summary-grid"><article><span>Total</span><strong><%= safeSliders.length %></strong></article><article><span>Active</span><strong><%= safeSliders.filter(s => s.active).length %></strong></article><article><span>Hidden</span><strong><%= safeSliders.filter(s => !s.active).length %></strong></article><article><span>With mobile image</span><strong><%= safeSliders.filter(s => s.mobileImage?.url).length %></strong></article></div>
<% if (safeSliders.length) { %><div class="admin-table-wrap"><table class="admin-products-table"><thead><tr><th>Slide</th><th>Position</th><th>Order</th><th>Status</th><th>Action</th></tr></thead><tbody><% safeSliders.forEach(slider => { %><tr>
<td><div class="admin-product-cell"><div class="admin-product-image"><img src="<%= slider.desktopImage?.url || 'https://via.placeholder.com/300x160?text=Hero' %>" alt="<%= slider.title || 'Hero slide' %>"></div><div><strong><%= slider.title || 'Untitled slide' %></strong><small><%= slider.subtitle || '' %></small><small><%= slider.buttonText || 'Shop Now' %> → <%= slider.buttonLink || '/shop' %></small></div></div></td><td><%= slider.textPosition %></td><td><%= slider.displayOrder || 0 %></td><td><span class="status-pill <%= slider.active ? 'active' : 'inactive' %>"><%= slider.active ? 'Active' : 'Inactive' %></span></td><td><div class="table-actions"><a class="btn small-btn" href="/admin/sliders/<%= slider._id %>/edit">Edit</a><% if (slider.active) { %><form method="post" action="/admin/sliders/<%= slider._id %>/delete" onsubmit="return confirm('Deactivate this slide?')"><button class="btn ghost-btn small-btn" type="submit">Deactivate</button></form><% } %></div></td>
</tr><% }) %></tbody></table></div><% } else { %><div class="empty-state"><h2>No hero slides yet</h2><p>Add your first admin-editable homepage hero.</p><a class="btn gold-btn" href="/admin/sliders/new">Add slide</a></div><% } %>
</section></div><%- include('../partials/footer') %>
