.checkout-coupon-icon{width:48px;height:48px;display:grid;place-items:center;border-radius:15px;background:#111;color:#d4ad49;font-weight:900;font-size:1.2rem}
.checkout-mini-label{display:block;margin-bottom:5px;color:#9a7018;font-size:.66rem;font-weight:850;letter-spacing:.16em}
.checkout-card-header{display:flex;align-items:center;justify-content:space-between;gap:16px;padding:22px 24px 14px}
.checkout-top-coupon-card .checkout-card-header{padding:0 0 13px}
.checkout-card-header h2{margin:0;font-size:clamp(1.14rem,2vw,1.42rem)}.checkout-card-header p{margin:5px 0 0;color:#706a61;font-size:.88rem}
.checkout-card-body{padding:0 24px 24px}.checkout-top-coupon-card .checkout-card-body{padding:0}
.checkout-coupon-form{display:grid;grid-template-columns:1fr auto;gap:10px}
.checkout-coupon-form input,.checkout-coupon-form button,.remove-coupon-button{min-height:46px;border-radius:13px}
.checkout-coupon-form input{width:100%;border:1px solid #d9d2c6;padding:0 14px}.checkout-coupon-form button,.remove-coupon-button{border:0;padding:0 18px;background:#111;color:#fff;font-weight:800}
.applied-coupon-box{min-height:52px;border:1px dashed #c99b31;border-radius:15px;background:#fffaf0;padding:10px 12px 10px 15px}
.checkout-item-count{min-width:58px;min-height:32px;display:grid;place-items:center;border-radius:999px;background:#f3ead3;color:#765914;font-size:.76rem;font-weight:800}
.checkout-summary-products{padding:0 24px;display:grid;gap:10px;max-height:176px;overflow:auto}
.checkout-summary-product{display:grid;grid-template-columns:56px minmax(0,1fr) auto;gap:12px;align-items:center;padding:10px;border:1px solid #eee9df;border-radius:15px;background:#fcfbf8}
.checkout-summary-product img{width:56px;height:66px;object-fit:cover;border-radius:11px}.checkout-summary-product-info{min-width:0}
.checkout-summary-product h3{margin:0 0 3px;font-size:.9rem;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}.checkout-summary-product p,.checkout-summary-product small{margin:0;color:#746f66;font-size:.75rem}
.checkout-total-list{display:grid;gap:9px;padding:16px 24px 22px}.checkout-total-list>div{display:flex;justify-content:space-between;gap:15px;font-size:.87rem}
.checkout-discount-row{color:#18864b}.checkout-grand-total{margin-top:2px;padding-top:12px;border-top:1px solid #e9e3d8;font-size:1.02rem!important}
.checkout-form-grid{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:16px;padding:0 24px 24px}.checkout-card-body .checkout-form-grid{padding:0}
.field{min-width:0}.field label{display:block;margin-bottom:7px;font-size:.82rem;font-weight:800}
.field input,.field select,.field textarea{width:100%;min-height:48px;border:1px solid #ddd7cc;border-radius:13px;background:#fff;padding:0 14px;font:inherit;outline:0}
.field textarea{min-height:106px;padding-top:13px;resize:vertical}.field input:focus,.field select:focus,.field textarea:focus{border-color:#c89c35;box-shadow:0 0 0 4px rgba(200,156,53,.12)}
.checkout-full-field{grid-column:1/-1}.checkout-area-picker{position:relative}
.checkout-area-suggestions{position:absolute;z-index:40;top:calc(100% + 7px);left:0;right:0;max-height:220px;overflow:auto;padding:7px;border:1px solid #ded7ca;border-radius:14px;background:#fff;box-shadow:0 18px 38px rgba(0,0,0,.14)}
.checkout-area-suggestions button{width:100%;min-height:42px;border:0;border-radius:10px;background:transparent;padding:9px 11px;text-align:left}.checkout-area-suggestions button:hover{background:#f5efe1}
.delivery-type-options{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:10px}
.checkout-submit-card{display:grid;grid-template-columns:minmax(0,1fr) minmax(240px,auto);gap:18px;align-items:center;padding:20px 22px;background:linear-gradient(135deg,#111,#2d281d);color:#fff}
.checkout-submit-copy{display:flex;align-items:center;gap:13px}.checkout-submit-lock{width:42px;height:42px;display:grid;place-items:center;border-radius:13px;background:rgba(255,255,255,.09)}
.checkout-submit-copy strong,.checkout-submit-copy small{display:block}.checkout-submit-copy small{margin-top:4px;color:rgba(255,255,255,.68)}
.checkout-place-order-button{width:100%;min-height:54px;display:flex;align-items:center;justify-content:space-between;gap:14px;border-radius:15px;background:#d1a741;color:#111;font-weight:900}
.checkout-policy-note{grid-column:1/-1;margin:-6px 0 0;color:rgba(255,255,255,.6);font-size:.74rem;text-align:center}
.coupon-message-success{color:#14833b!important}.coupon-message-error{color:#b42a2a!important}
@media(max-width:860px){.checkout-top-grid{grid-template-columns:1fr}.checkout-form-grid{grid-template-columns:1fr}.checkout-full-field{grid-column:auto}.checkout-submit-card{grid-template-columns:1fr}}
@media(max-width:560px){.checkout-page-section{padding:16px 0 34px}.checkout-page-section .container{padding-left:12px;padding-right:12px}.checkout-page-heading h1{font-size:1.5rem}.checkout-card,.checkout-submit-card{border-radius:17px}.checkout-top-coupon-card{grid-template-columns:1fr;padding:18px}.checkout-card-header{padding:18px 16px 12px}.checkout-card-body{padding:0 16px 18px}.checkout-form-grid{gap:13px;padding:0 16px 18px}.checkout-coupon-form{grid-template-columns:1fr}.checkout-coupon-form button{width:100%}.checkout-summary-products{padding:0 14px;max-height:none}.checkout-summary-product{grid-template-columns:50px minmax(0,1fr)}.checkout-summary-product img{width:50px;height:58px}.checkout-summary-product>strong{grid-column:2;margin-top:-5px}.checkout-total-list{padding:14px 16px 18px}.field input,.field select,.field textarea{font-size:16px}.checkout-submit-card{padding:18px 16px}}
</style>

<section class="section checkout-page-section">

  <div class="container">

    <div class="checkout-page-heading">
      <div>
        <span class="section-kicker">
          SECURE CHECKOUT
        </span>

        <h1>Complete Your Order</h1>
      </div>

      <% if (!currentUser) { %>
        <a class="checkout-login-link" href="/login">
          Already registered? Login
        </a>
      <% } %>
    </div>


    <div class="checkout-top-grid">
      <section class="checkout-card checkout-top-coupon-card">
        <div class="checkout-coupon-icon">%</div>
        <div class="checkout-coupon-content">
          <header class="checkout-card-header">
            <div>
              <span class="checkout-mini-label">SPECIAL OFFER</span>
              <h2>Have a Coupon?</h2>
              <p>Enter your code to unlock your discount.</p>
            </div>
          </header>

          <div class="checkout-card-body">
            <div class="checkout-coupon-area" id="checkoutCouponArea">
              <div class="applied-coupon-box" id="appliedCouponBox" <%= coupon ? '' : 'hidden' %>>
                <div>
                  <span>Coupon applied</span>
                  <strong id="appliedCouponCode"><%= coupon?.code || '' %></strong>
                </div>
                <button type="button" class="remove-coupon-button" id="removeCouponButton">Remove</button>
              </div>

              <div class="checkout-coupon-form" id="couponApplyBox" <%= coupon ? 'hidden' : '' %>>
                <input type="text" id="couponCodeInput" placeholder="Enter coupon code" autocomplete="off">
                <button type="button" id="applyCouponButton">Apply</button>
              </div>

              <p class="field-help" id="couponMessage" aria-live="polite"></p>
            </div>
          </div>
        </div>
      </section>

      <aside class="checkout-card checkout-summary-card checkout-summary-compact">
        <header class="checkout-card-header checkout-summary-header">
          <div>
            <span class="checkout-mini-label">YOUR ORDER</span>
            <h2>Order Summary</h2>
          </div>
          <span class="checkout-item-count"><%= cartCount %> <%= cartCount === 1 ? 'item' : 'items' %></span>
        </header>

        <div class="checkout-summary-products">
          <% cart.forEach(item => { %>
            <article class="checkout-summary-product">
              <img src="<%= item.image || 'https://via.placeholder.com/160x200?text=TTT' %>" alt="<%= item.name %>">
              <div class="checkout-summary-product-info">
                <h3><%= item.name %></h3>
                <p><%= item.color %> · <%= item.size %></p>
                <small>Quantity: <%= item.quantity %></small>
              </div>
              <strong>৳<%= money(Number(item.price) * Number(item.quantity)) %></strong>
            </article>
          <% }) %>
        </div>

        <div class="checkout-total-list">
          <div><span>Subtotal</span><strong>৳<%= money(subtotal) %></strong></div>
          <div>
            <span>Delivery Fee</span>
            <strong><% if (Number(deliveryFee) === 0) { %>Free<% } else { %>৳<%= money(deliveryFee) %><% } %></strong>
          </div>
          <div class="checkout-discount-row" id="checkoutDiscountRow" <%= finalDiscount > 0 ? '' : 'hidden' %>>
            <span>Discount</span>
            <strong id="checkoutDiscountAmount">− ৳<%= money(finalDiscount) %></strong>
          </div>
          <div class="checkout-grand-total">
            <span>Total</span>
            <strong id="checkoutGrandTotal">৳<%= money(finalTotal) %></strong>
          </div>
        </div>
      </aside>
    </div>

    <div class="checkout-professional-layout">

      <!-- =====================================
           LEFT SIDE: CHECKOUT FORM
      ====================================== -->

      <form
        class="checkout-main-form"
        method="post"
        action="/checkout"
      >

        <% if (
          typeof wholesaleDiscount !== 'undefined' &&
          Number(wholesaleDiscount || 0) > 0
        ) { %>
          <div class="checkout-wholesale-banner">
            <strong>Wholesale discount applied</strong>
            <span>
              You saved ৳<%= money(wholesaleDiscount) %>
              on this bulk order.
            </span>
          </div>
        <% } %>

        <!-- SHIPPING ADDRESS -->

        <section class="checkout-card checkout-address-card">

          <header class="checkout-card-header">
<div>
              <h2>Shipping Address</h2>

              <p>
                Enter the address where you want to
                receive your order.
              </p>
            </div>
          </header>

          <div class="checkout-form-grid">

            <div class="field">
              <label for="customerName">
                Recipient Name
                <span class="required-mark">*</span>
              </label>

              <input
                id="customerName"
                type="text"
                name="name"
                value="<%= user?.name || '' %>"
                placeholder="Full Name"
                autocomplete="name"
                required
              >
            </div>

            <div class="field">
              <label for="customerPhone">
                Contact Number
                <span class="required-mark">*</span>
              </label>

              <input
                id="customerPhone"
                type="tel"
                name="phone"
                value="<%= user?.phone || '' %>"
                placeholder="01XXXXXXXXX"
                maxlength="11"
                inputmode="numeric"
                autocomplete="tel"
                pattern="01[0-9]{9}"
                required
              >

              <small class="field-help">
                Enter a valid 11-digit Bangladeshi number.
              </small>
            </div>

            <div class="field">
              <label for="customerEmail">
                Email Address
              </label>

              <input
                id="customerEmail"
                type="email"
                name="email"
                value="<%= user?.email || '' %>"
                placeholder="example@email.com"
                autocomplete="email"
              >

              <small class="field-help">
                Order confirmation will be sent to this email.
              </small>
            </div>

            <div class="field">
              <label for="country">
                Country
              </label>

              <select
                id="country"
                name="country"
                autocomplete="country-name"
              >
                <option value="Bangladesh" selected>
                  Bangladesh
                </option>
              </select>
            </div>

            <div class="field">
              <label for="city">
                District / City
                <span class="required-mark">*</span>
              </label>

              <select id="city" name="city" autocomplete="address-level1" required>
                <option value="">Select District / City</option>
                <option value="Bagerhat" <%= defaultAddress?.city === 'Bagerhat' ? 'selected' : '' %>>Bagerhat</option>
                <option value="Bandarban" <%= defaultAddress?.city === 'Bandarban' ? 'selected' : '' %>>Bandarban</option>
