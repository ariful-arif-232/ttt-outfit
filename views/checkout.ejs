<section class="section checkout-page-section">

  <div class="container">

    <div class="checkout-page-heading">
      <div>
        <span class="section-kicker">
          SECURE CHECKOUT
        </span>

        <h1>Complete Your Order</h1>
      </div>

      <% if (!currentUser) { %>
        <a class="checkout-login-link" href="/login">
          Already registered? Login
        </a>
      <% } %>
    </div>


    <div class="checkout-top-grid">
      <section class="checkout-card checkout-top-coupon-card">
        <div class="checkout-coupon-icon">%</div>
        <div class="checkout-coupon-content">
          <header class="checkout-card-header">
            <div>
              <span class="checkout-mini-label">SPECIAL OFFER</span>
              <h2>Have a Coupon?</h2>
              <p>Enter your code to unlock your discount.</p>
            </div>
          </header>

          <div class="checkout-card-body">
            <div class="checkout-coupon-area" id="checkoutCouponArea">
              <div class="applied-coupon-box" id="appliedCouponBox" <%= coupon ? '' : 'hidden' %>>
                <div>
                  <span>Coupon applied</span>
                  <strong id="appliedCouponCode"><%= coupon?.code || '' %></strong>
                </div>
                <button type="button" class="remove-coupon-button" id="removeCouponButton">Remove</button>
              </div>

              <div class="checkout-coupon-form" id="couponApplyBox" <%= coupon ? 'hidden' : '' %>>
                <input type="text" id="couponCodeInput" placeholder="Enter coupon code" autocomplete="off">
                <button type="button" id="applyCouponButton">Apply</button>
              </div>

              <p class="field-help" id="couponMessage" aria-live="polite"></p>
            </div>
          </div>
        </div>
      </section>

      <aside class="checkout-card checkout-summary-card checkout-summary-compact">
        <header class="checkout-card-header checkout-summary-header">
          <div>
            <span class="checkout-mini-label">YOUR ORDER</span>
            <h2>Order Summary</h2>
          </div>
          <span class="checkout-item-count"><%= cartCount %> <%= cartCount === 1 ? 'item' : 'items' %></span>
        </header>

        <div class="checkout-summary-products">
          <% cart.forEach(item => { %>
            <article class="checkout-summary-product">
              <img src="<%= item.image || 'https://via.placeholder.com/160x200?text=TTT' %>" alt="<%= item.name %>">
              <div class="checkout-summary-product-info">
                <h3><%= item.name %></h3>
                <p><%= item.color %> · <%= item.size %></p>
                <small>Quantity: <%= item.quantity %></small>
              </div>
              <strong>৳<%= money(Number(item.price) * Number(item.quantity)) %></strong>
            </article>
          <% }) %>
        </div>

        <div class="checkout-total-list">
          <div><span>Subtotal</span><strong>৳<%= money(subtotal) %></strong></div>
          <div>
            <span>Delivery Fee</span>
            <strong><% if (Number(deliveryFee) === 0) { %>Free<% } else { %>৳<%= money(deliveryFee) %><% } %></strong>
          </div>
          <div class="checkout-discount-row" id="checkoutDiscountRow" <%= finalDiscount > 0 ? '' : 'hidden' %>>
            <span>Discount</span>
            <strong id="checkoutDiscountAmount">− ৳<%= money(finalDiscount) %></strong>
          </div>
          <div class="checkout-grand-total">
            <span>Total</span>
            <strong id="checkoutGrandTotal">৳<%= money(finalTotal) %></strong>
          </div>
        </div>
      </aside>
    </div>

    <div class="checkout-professional-layout">

      <!-- =====================================
           LEFT SIDE: CHECKOUT FORM
      ====================================== -->

      <form
        class="checkout-main-form"
        method="post"
        action="/checkout"
      >

        <% if (
          typeof wholesaleDiscount !== 'undefined' &&
          Number(wholesaleDiscount || 0) > 0
        ) { %>
          <div class="checkout-wholesale-banner">
            <strong>Wholesale discount applied</strong>
            <span>
              You saved ৳<%= money(wholesaleDiscount) %>
              on this bulk order.
            </span>
          </div>
        <% } %>

