/* ===== Premium Checkout Visual Upgrade ===== */
.checkout-page-section{
  position:relative;
  isolation:isolate;
  overflow:hidden;
  background:
    radial-gradient(circle at 8% 0%,rgba(209,167,65,.18),transparent 26%),
    radial-gradient(circle at 92% 16%,rgba(17,17,17,.06),transparent 22%),
    linear-gradient(180deg,#fbfaf7 0%,#f3efe7 100%);
}

.checkout-page-section::before,
.checkout-page-section::after{
  content:"";
  position:absolute;
  z-index:-1;
  border-radius:999px;
  filter:blur(18px);
  pointer-events:none;
}

.checkout-page-section::before{
  width:220px;
  height:220px;
  top:40px;
  left:-80px;
  background:rgba(209,167,65,.13);
}

.checkout-page-section::after{
  width:260px;
  height:260px;
  right:-100px;
  bottom:70px;
  background:rgba(0,0,0,.055);
}

.checkout-page-heading{
  padding:4px 2px 8px;
}

.checkout-page-heading .section-kicker{
  display:inline-flex;
  align-items:center;
  gap:7px;
}

.checkout-page-heading .section-kicker::before{
  content:"";
  width:22px;
  height:1px;
  background:#b9891d;
}

.checkout-card,
.checkout-submit-card{
  border:1px solid rgba(255,255,255,.72);
  background:rgba(255,255,255,.82);
  backdrop-filter:blur(18px);
  -webkit-backdrop-filter:blur(18px);
  box-shadow:
    0 18px 48px rgba(27,23,15,.08),
    inset 0 1px 0 rgba(255,255,255,.82);
}

.checkout-card{
  transition:transform .25s ease,box-shadow .25s ease,border-color .25s ease;
}

.checkout-card:hover{
  transform:translateY(-2px);
  border-color:rgba(201,157,54,.28);
  box-shadow:
    0 22px 56px rgba(27,23,15,.11),
    inset 0 1px 0 rgba(255,255,255,.9);
}

.checkout-top-coupon-card{
  position:relative;
  overflow:hidden;
  background:
    linear-gradient(135deg,rgba(214,175,77,.23),rgba(255,255,255,.88) 58%),
    rgba(255,255,255,.8);
}

.checkout-top-coupon-card::after{
  content:"";
  position:absolute;
  width:150px;
  height:150px;
  right:-45px;
  top:-65px;
  border-radius:50%;
  border:26px solid rgba(201,157,54,.09);
  animation:couponFloat 5s ease-in-out infinite;
}

.checkout-coupon-icon{
  position:relative;
  z-index:1;
  box-shadow:0 12px 28px rgba(17,17,17,.18);
  animation:couponPulse 2.8s ease-in-out infinite;
}

@keyframes couponFloat{
  0%,100%{transform:translate3d(0,0,0) rotate(0deg)}
  50%{transform:translate3d(-8px,10px,0) rotate(8deg)}
}

@keyframes couponPulse{
  0%,100%{transform:scale(1)}
  50%{transform:scale(1.045)}
}

.checkout-coupon-form input{
  background:rgba(255,255,255,.86);
  border-color:rgba(174,150,99,.28);
  box-shadow:inset 0 1px 0 rgba(255,255,255,.85);
}

.checkout-coupon-form button,
.remove-coupon-button{
  position:relative;
  overflow:hidden;
  box-shadow:0 10px 22px rgba(17,17,17,.14);
  transition:transform .2s ease,box-shadow .2s ease;
}

.checkout-coupon-form button:hover,
.remove-coupon-button:hover{
  transform:translateY(-1px);
  box-shadow:0 14px 28px rgba(17,17,17,.18);
}

.checkout-summary-card{
