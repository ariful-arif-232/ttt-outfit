<%- include('partials/header') %>

<%
  const defaultAddress =
    user?.addresses?.find(address => address.isDefault) ||
    user?.addresses?.[0] ||
    null;

  const finalDiscount = Number(discount || 0);

  const finalTotal =
    typeof total !== 'undefined'
      ? Number(total)
      : Number(subtotal || 0) +
        Number(deliveryFee || 0) -
        finalDiscount;
%>


<style>
.checkout-page-section{padding:30px 0 60px;background:radial-gradient(circle at top left,rgba(201,157,54,.1),transparent 28%),#f7f5f1}
