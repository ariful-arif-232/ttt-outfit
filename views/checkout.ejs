                <option value="Chandpur" <%= defaultAddress?.city === 'Chandpur' ? 'selected' : '' %>>Chandpur</option>
                <option value="Chapai Nawabganj" <%= defaultAddress?.city === 'Chapai Nawabganj' ? 'selected' : '' %>>Chapai Nawabganj</option>
