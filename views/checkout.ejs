.checkout-page-heading{display:flex;align-items:flex-end;justify-content:space-between;gap:18px;margin-bottom:18px}
.checkout-page-heading h1{margin:6px 0 0;font-size:clamp(1.6rem,3vw,2.2rem);line-height:1.1;letter-spacing:-.035em}
.checkout-top-grid{display:grid;grid-template-columns:minmax(0,.9fr) minmax(0,1.1fr);gap:18px;margin-bottom:18px}
.checkout-professional-layout{display:block}.checkout-main-form{display:grid;gap:18px}
.checkout-card,.checkout-submit-card{border:1px solid rgba(20,20,20,.08);border-radius:22px;background:#fff;box-shadow:0 12px 38px rgba(20,20,20,.06);overflow:visible}
