        </section>


        <section class="checkout-submit-card">
          <div class="checkout-submit-copy">
            <span class="checkout-submit-lock">🔒</span>
            <div>
              <strong>Secure order confirmation</strong>
              <small>Review your information before placing the order.</small>
            </div>
          </div>

          <button class="btn checkout-place-order-button" type="submit">
            <span>Place Order</span>
            <strong id="placeOrderTotal">৳<%= money(finalTotal) %></strong>
          </button>

          <p class="checkout-policy-note">
            By placing this order, you confirm that the information provided is correct.
          </p>
        </section>

      </form>



    </div>

  </div>

</section>


<script>
  document.addEventListener('DOMContentLoaded', () => {
    const paymentMethod =
      document.getElementById('paymentMethod');

    const manualPaymentBox =
      document.getElementById('manualPaymentBox');

    const paymentTitle =
      document.getElementById('paymentTitle');

    const paymentNumber =
      document.getElementById('paymentNumber');

    const senderNumber =
      document.getElementById('senderNumber');

    const transactionId =
      document.getElementById('transactionId');

    const bkashNumber =
      <%- JSON.stringify(bkashNumber || '') %>;

    const nagadNumber =
      <%- JSON.stringify(nagadNumber || '') %>;

    function updatePaymentFields() {
      if (
        !paymentMethod ||
        !manualPaymentBox ||
        !senderNumber ||
        !transactionId
      ) {
        return;
      }

      const method = paymentMethod.value;

      const isManual =
        method === 'bKash' ||
        method === 'Nagad';

      manualPaymentBox.hidden = !isManual;

      senderNumber.required = isManual;
      transactionId.required = isManual;

      if (method === 'bKash') {
        paymentTitle.textContent =
          'Pay with bKash';

        paymentNumber.textContent =
          bkashNumber ||
          'Number not configured';
      }

      if (method === 'Nagad') {
        paymentTitle.textContent =
          'Pay with Nagad';

        paymentNumber.textContent =
          nagadNumber ||
          'Number not configured';
      }

      if (!isManual) {
        senderNumber.value = '';
        transactionId.value = '';
        paymentNumber.textContent = '';
      }
    }

    paymentMethod?.addEventListener(
      'change',
      updatePaymentFields
    );

    updatePaymentFields();

    /* AJAX COUPON APPLY / REMOVE */

    const couponCodeInput =
      document.getElementById('couponCodeInput');

    const applyCouponButton =
      document.getElementById('applyCouponButton');

    const removeCouponButton =
      document.getElementById('removeCouponButton');

    const couponApplyBox =
      document.getElementById('couponApplyBox');

    const appliedCouponBox =
      document.getElementById('appliedCouponBox');

    const appliedCouponCode =
      document.getElementById('appliedCouponCode');

    const couponMessage =
      document.getElementById('couponMessage');

    const discountRow =
      document.getElementById('checkoutDiscountRow');

    const discountAmount =
      document.getElementById('checkoutDiscountAmount');

    const grandTotal =
      document.getElementById('checkoutGrandTotal');

    const placeOrderTotal =
      document.getElementById('placeOrderTotal');

    const formatMoney = value =>
      Number(value || 0).toLocaleString(
        'en-BD',
        {
          minimumFractionDigits: 0,
          maximumFractionDigits: 2
        }
      );

    function setCouponMessage(message, type = '') {
      if (!couponMessage) return;

      couponMessage.textContent = message || '';
      couponMessage.classList.remove(
        'coupon-message-success',
        'coupon-message-error'
      );

      if (type === 'success') {
        couponMessage.classList.add('coupon-message-success');
      }

      if (type === 'error') {
        couponMessage.classList.add('coupon-message-error');
      }
    }

    function updateCheckoutTotals(data) {
      const discount = Number(data.discount || 0);
      const total = Number(data.total || 0);

      if (discountRow) {
        discountRow.hidden = discount <= 0;
      }

      if (discountAmount) {
        discountAmount.textContent =
          `− ৳${formatMoney(discount)}`;
      }

      if (grandTotal) {
        grandTotal.textContent =
          `৳${formatMoney(total)}`;
      }

      if (placeOrderTotal) {
        placeOrderTotal.textContent =
          `৳${formatMoney(total)}`;
      }
    }

    async function sendCouponRequest(url, body = {}) {
      const response = await fetch(url, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json'
        },
        body: JSON.stringify(body)
      });

      const data = await response.json();

      if (!response.ok || !data.success) {
        throw new Error(
          data.message || 'Coupon request failed.'
        );
      }

      return data;
    }

    applyCouponButton?.addEventListener('click', async () => {
      const code = String(couponCodeInput?.value || '')
        .trim()
        .toUpperCase();

      if (!code) {
        setCouponMessage('Enter a coupon code.', 'error');
        couponCodeInput?.focus();
        return;
      }

      applyCouponButton.disabled = true;
      applyCouponButton.textContent = 'Applying...';
      setCouponMessage('');

      try {
        const data = await sendCouponRequest(
          '/coupon/apply',
          { code }
        );

        if (appliedCouponCode) {
          appliedCouponCode.textContent = data.coupon.code;
        }

        if (couponApplyBox) couponApplyBox.hidden = true;
        if (appliedCouponBox) appliedCouponBox.hidden = false;

        updateCheckoutTotals(data);
        setCouponMessage(data.message, 'success');
      } catch (error) {
        setCouponMessage(error.message, 'error');
      } finally {
        applyCouponButton.disabled = false;
        applyCouponButton.textContent = 'Apply';
      }
    });

    couponCodeInput?.addEventListener('keydown', event => {
      if (event.key === 'Enter') {
        event.preventDefault();
        applyCouponButton?.click();
      }
    });

    removeCouponButton?.addEventListener('click', async () => {
      removeCouponButton.disabled = true;
      removeCouponButton.textContent = 'Removing...';
      setCouponMessage('');

      try {
        const data = await sendCouponRequest('/coupon/remove');

        if (appliedCouponBox) appliedCouponBox.hidden = true;
        if (couponApplyBox) couponApplyBox.hidden = false;
        if (couponCodeInput) couponCodeInput.value = '';

        updateCheckoutTotals(data);
        setCouponMessage(data.message, 'success');
      } catch (error) {
        setCouponMessage(error.message, 'error');
      } finally {
        removeCouponButton.disabled = false;
        removeCouponButton.textContent = 'Remove';
      }
    });

    /* Mobile-friendly area suggestions */
    const cityField = document.getElementById('city');
    const areaField = document.getElementById('area');
    const areaSuggestionList = document.getElementById('areaSuggestionList');

    const areaDirectory = {
      Dhaka: ['Dhanmondi','Mirpur','Uttara','Mohammadpur','Bashundhara','Badda','Banani','Gulshan','Motijheel','Jatrabari','Savar','Ashulia','Keraniganj','Demra','Khilgaon'],
      Gazipur: ['Gazipur Sadar','Tongi','Kaliakair','Kapasia','Kaliganj','Sreepur'],
      Narayanganj: ['Narayanganj Sadar','Fatullah','Siddhirganj','Rupganj','Sonargaon','Araihazar'],
      Chattogram: ['Chattogram Sadar','Pahartali','Panchlaish','Halishahar','Agrabad','Patenga','Hathazari','Sitakunda'],
      Cumilla: ['Cumilla Sadar','Daudkandi','Debidwar','Chandina','Burichang','Laksam'],
      Sylhet: ['Sylhet Sadar','Beanibazar','Golapganj','South Surma','Fenchuganj','Kanaighat'],
      Rajshahi: ['Rajshahi Sadar','Boalia','Motihar','Paba','Godagari','Bagha'],
      Khulna: ['Khulna Sadar','Sonadanga','Khalishpur','Daulatpur','Dumuria','Rupsa'],
      Rangpur: ['Rangpur Sadar','Mithapukur','Badarganj','Kaunia','Pirganj','Gangachara'],
      Mymensingh: ['Mymensingh Sadar','Trishal','Bhaluka','Muktagacha','Gafargaon','Fulbaria']
    };

    function getAreaSuggestions() {
      const selectedCity = cityField?.value || '';
      return (areaDirectory[selectedCity] || [`${selectedCity} Sadar`,'City Area','Municipality Area']).filter(Boolean);
    }

    function renderAreaSuggestions() {
      if (!areaField || !areaSuggestionList) return;

      const query = areaField.value.trim().toLowerCase();
      const suggestions = getAreaSuggestions()
        .filter(area => !query || area.toLowerCase().includes(query))
        .slice(0, 10);

      areaSuggestionList.innerHTML = '';

      if (!suggestions.length) {
        areaSuggestionList.hidden = true;
        return;
      }

      suggestions.forEach(area => {
        const button = document.createElement('button');
        button.type = 'button';
        button.textContent = area;
        button.setAttribute('role', 'option');
        button.addEventListener('click', () => {
          areaField.value = area;
          areaSuggestionList.hidden = true;
          areaField.focus();
        });
        areaSuggestionList.appendChild(button);
      });

      areaSuggestionList.hidden = false;
    }

    areaField?.addEventListener('focus', renderAreaSuggestions);
    areaField?.addEventListener('input', renderAreaSuggestions);

    cityField?.addEventListener('change', () => {
      if (areaField) {
        areaField.value = '';
        areaField.focus();
      }
      renderAreaSuggestions();
    });

    document.addEventListener('click', event => {
      if (!areaSuggestionList || !areaField) return;
      if (event.target !== areaField && !areaSuggestionList.contains(event.target)) {
        areaSuggestionList.hidden = true;
      }
    });

  });
</script>
<script src="/js/bd-addresses.js"></script>
<%- include('partials/footer') %>
